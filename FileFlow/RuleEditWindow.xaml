<Window x:Class="FileFlow.RuleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="분류 규칙 편집" Width="680" Height="620" MinWidth="600" MinHeight="550"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F8F9FA">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="24"/><RowDefinition Height="Auto"/><RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="Auto"/><RowDefinition Height="16"/>
            <RowDefinition Height="*"/><RowDefinition Height="24"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0">
            <TextBlock Text="규칙 이름" FontWeight="Bold" FontSize="16" Margin="0,0,0,8" Foreground="#111827"/>
            <TextBox x:Name="TxtRuleName" />
        </StackPanel>
        
        <StackPanel Grid.Row="2">
            <TextBlock Text="조건 추가" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="#111827"/>
            <Border BorderThickness="1" BorderBrush="#E5E7EB" CornerRadius="8" Padding="16" Background="White">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="150"/><ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CmbType" Grid.Column="0">
                            <ComboBoxItem Content="확장자" Tag="Extension" IsSelected="True"/>
                            <ComboBoxItem Content="키워드" Tag="Keyword"/>
                            <ComboBoxItem Content="크기" Tag="Size"/>
                            <ComboBoxItem Content="날짜(연도)" Tag="DateYear"/>
                            <ComboBoxItem Content="날짜(월)" Tag="DateMonth"/>
                        </ComboBox>
                        <ComboBox x:Name="CmbOperator" Grid.Column="2">
                            <ComboBoxItem Content="일치" Tag="Equals" IsSelected="True"/>
                            <ComboBoxItem Content="포함" Tag="Contains"/>
                            <ComboBoxItem Content="시작" Tag="StartsWith"/>
                            <ComboBoxItem Content="끝" Tag="EndsWith"/>
                            <ComboBoxItem Content="초과" Tag="GreaterThan"/>
                            <ComboBoxItem Content="미만" Tag="LessThan"/>
                            <ComboBoxItem Content="정규식" Tag="Regex"/>
                        </ComboBox>
                        <TextBox x:Name="TxtValue" Grid.Column="4" />
                        <ComboBox x:Name="CmbUnit" Grid.Column="6">
                            <ComboBoxItem Content="" Tag="" IsSelected="True"/>
                            <ComboBoxItem Content="KB" Tag="KB"/>
                            <ComboBoxItem Content="MB" Tag="MB"/>
                            <ComboBoxItem Content="GB" Tag="GB"/>
                        </ComboBox>
                    </Grid>
                    <Button x:Name="BtnAddCondition" Content="+ 조건 추가" HorizontalAlignment="Left" Background="#10B981" Foreground="White" Click="BtnAddCondition_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
        
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <TextBlock Text="조건 연산:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0" Foreground="#4B5563"/>
            <RadioButton x:Name="RbAnd" Content="AND (모든 조건 충족)" IsChecked="True" Margin="0,0,24,0"/>
            <RadioButton x:Name="RbOr" Content="OR (하나라도 충족)"/>
        </StackPanel>
        
        <TextBlock Grid.Row="6" Text="추가된 조건" FontWeight="Bold" FontSize="16" Foreground="#111827"/>
        <ListView x:Name="ConditionList" Grid.Row="8" BorderBrush="#E5E7EB" BorderThickness="1" Background="White">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="조건 요약" Width="430" DisplayMemberBinding="{Binding Display}"/>
                    <GridViewColumn Header="" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="삭제" Tag="{Binding}" Foreground="#EF4444" Background="Transparent" Padding="4,2" Click="BtnRemoveCondition_Click"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="대상 경로 패턴" FontWeight="Bold" FontSize="16" Margin="0,0,0,8" Foreground="#111827"/>
                <TextBox x:Name="TxtTargetPath" />
                <TextBlock Text="사용 가능: {year}/{년} {month}/{월} {day}/{일} {ext} {keyword} {size}" FontSize="12" Foreground="#9CA3AF" Margin="0,6,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="24,28,0,0">
                <Button x:Name="BtnCancel" Content="취소" Width="80" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                <Button x:Name="BtnOk" Content="확인 저장" Width="100" Background="#2563EB" Foreground="White" Click="BtnOk_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
