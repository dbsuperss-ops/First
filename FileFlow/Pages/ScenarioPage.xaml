<Page x:Class="FileFlow.Pages.ScenarioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F8F9FA">
    <Grid Margin="24,20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="시나리오 관리" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnImportScenario" Content="📥 가져오기" Margin="0,0,8,0" Click="BtnImportScenario_Click"/>
                <Button x:Name="BtnExportScenario" Content="📤 내보내기" Click="BtnExportScenario_Click"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Padding="16" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="목록" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="BtnAddScenario" Content="+ 추가" Background="#2563EB" Foreground="White" Click="BtnAddScenario_Click"/>
                    </Grid>
                    <ListBox x:Name="ScenarioList" Grid.Row="2" BorderThickness="0" Background="Transparent" SelectionChanged="ScenarioList_SelectionChanged"/>
                </Grid>
            </Border>
            <Border Grid.Column="2" Padding="24,20" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="시나리오 설정" FontSize="18" FontWeight="Bold" Margin="0,0,16,0"/>
                                <CheckBox x:Name="ChkIsActive" Content="활성화 (감시 및 예약실행 대상)" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center" Click="ChkIsActive_Click"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="BtnDeleteScenario" Content="삭제" Foreground="#EF4444" Click="BtnDeleteScenario_Click"/>
                            <Button Grid.Column="3" x:Name="BtnSave" Content="저장" Background="#2563EB" Foreground="White" Click="BtnSave_Click"/>
                        </Grid>
                        
                        <TextBlock Text="시나리오 이름" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#4B5563"/>
                        <TextBox x:Name="TxtScenarioName" Margin="0,0,0,24"/>
                        
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="원본 폴더" FontWeight="SemiBold" Foreground="#4B5563"/>
                            <Grid Grid.Row="2" Grid.Column="0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtSourceFolder" Grid.Column="0"/>
                                <Button Grid.Column="2" Content="찾기" Width="60" Click="BtnBrowseSource_Click"/>
                            </Grid>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="대상 폴더" FontWeight="SemiBold" Foreground="#4B5563"/>
                            <Grid Grid.Row="2" Grid.Column="2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtTargetFolder" Grid.Column="0"/>
                                <Button Grid.Column="2" Content="찾기" Width="60" Click="BtnBrowseTarget_Click"/>
                            </Grid>
                        </Grid>

                        <TextBlock Text="규칙 관리" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10" Foreground="#111827"/>
                        <Grid Height="160" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                            <ListView x:Name="RuleList" Grid.Column="0" BorderBrush="#E5E7EB" BorderThickness="1">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="규칙명" Width="150" DisplayMemberBinding="{Binding RuleName}"/>
                                        <GridViewColumn Header="대상 경로" Width="180" DisplayMemberBinding="{Binding TargetPath}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <Button Content="+ 규칙 추가" Margin="0,0,0,8" Click="BtnAddRule_Click"/>
                                <Button Content="규칙 수정" Margin="0,0,0,8" Click="BtnEditRule_Click"/>
                                <Button Content="규칙 삭제" Margin="0,0,0,20" Foreground="#EF4444" Click="BtnDeleteRule_Click"/>
                                <Button Content="✨ 통계 제안" Background="#10B981" Foreground="White" Click="BtnSuggestRules_Click"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="옵션" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10" Foreground="#111827"/>
                        <Border Background="#F9FAFB" CornerRadius="8" Padding="20,16" Margin="0,0,0,24" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <CheckBox x:Name="ChkSubfolders" Content="하위 폴더 포함" Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkExcludeSystem" Content="시스템/숨김 파일 제외" Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkCleanupEmpty" Content="이동 후 빈 폴더 정리" Margin="0,0,0,16"/>
                                <TextBlock Text="파일 충돌 처리" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#4B5563"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="RbConflictSkip" Content="건너뛰기" Margin="0,0,24,0"/>
                                    <RadioButton x:Name="RbConflictRename" Content="이름 변경" IsChecked="True" Margin="0,0,24,0"/>
                                    <RadioButton x:Name="RbConflictOverwrite" Content="덮어쓰기"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="스케줄링 (예약 실행)" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10" Foreground="#111827"/>
                        <Border Background="#F9FAFB" CornerRadius="8" Padding="20,16" Margin="0,0,0,24" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <CheckBox x:Name="ChkIsScheduled" Content="윈도우 예약 실행 활성화" FontWeight="SemiBold" Margin="0,0,0,16" Click="ChkIsScheduled_Click"/>
                                <StackPanel x:Name="PnlSchedule" IsEnabled="False">
                                    <TextBlock Text="실행 요일" Margin="0,0,0,8" Foreground="#4B5563"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <CheckBox x:Name="ChkMon" Content="월" Margin="0,0,12,0"/>
                                        <CheckBox x:Name="ChkTue" Content="화" Margin="0,0,12,0"/>
                                        <CheckBox x:Name="ChkWed" Content="수" Margin="0,0,12,0"/>
                                        <CheckBox x:Name="ChkThu" Content="목" Margin="0,0,12,0"/>
                                        <CheckBox x:Name="ChkFri" Content="금" Margin="0,0,12,0"/>
                                        <CheckBox x:Name="ChkSat" Content="토" Margin="0,0,12,0"/>
                                        <CheckBox x:Name="ChkSun" Content="일"/>
                                    </StackPanel>
                                    <TextBlock Text="실행 시간 (HH:mm 형식)" Margin="0,0,0,8" Foreground="#4B5563"/>
                                    <TextBox x:Name="TxtScheduleTime" Width="120" HorizontalAlignment="Left" Text="09:00"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnWatchStart" Content="👁 실시간 감시 시작" Background="#8B5CF6" Foreground="White" Click="BtnWatchStart_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
