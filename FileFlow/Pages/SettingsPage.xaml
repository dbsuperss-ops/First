<Page x:Class="FileFlow.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F8F9FA">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="960">
            <TextBlock Text="설정" FontSize="28" FontWeight="Bold" Margin="0,0,0,28"/>
            <TextBlock Text="기본 폴더 설정" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#111827"/>
            <Border Padding="24,20" Margin="0,0,0,24" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="기본 원본 폴더" FontWeight="SemiBold" Foreground="#4B5563"/>
                        <Grid Grid.Row="2" Grid.Column="0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtDefaultSource" Grid.Column="0"/>
                            <Button Grid.Column="2" Content="찾기" Width="60" Click="BtnBrowseSource_Click"/></Grid>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="기본 대상 폴더" FontWeight="SemiBold" Foreground="#4B5563"/>
                        <Grid Grid.Row="2" Grid.Column="2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtDefaultTarget" Grid.Column="0"/>
                            <Button Grid.Column="2" Content="찾기" Width="60" Click="BtnBrowseTarget_Click"/></Grid>
                    </Grid>
                    <Button x:Name="BtnSave" Content="설정 저장" Background="#2563EB" Foreground="White" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
            
            <TextBlock Text="데이터 관리" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#111827"/>
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Padding="20,24" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="로그 초기화" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,16" Foreground="#4B5563"/><Button x:Name="BtnClearLogs" Content="로그 삭제" HorizontalAlignment="Center" Foreground="#EF4444" Click="BtnClearLogs_Click"/></StackPanel></Border>
                <Border Grid.Column="2" Padding="20,24" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="시나리오 초기화" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,16" Foreground="#4B5563"/><Button x:Name="BtnResetScenarios" Content="초기화" HorizontalAlignment="Center" Foreground="#F59E0B" Click="BtnResetScenarios_Click"/></StackPanel></Border>
                <Border Grid.Column="4" Padding="20,24" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="테스트 파일" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,16" Foreground="#4B5563"/><Button x:Name="BtnResetTestFiles" Content="파일 생성" HorizontalAlignment="Center" Click="BtnResetTestFiles_Click"/></StackPanel></Border>
            </Grid>
            
            <TextBlock Text="시스템 정보" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#111827"/>
            <Border Padding="24,20" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="에러 로그 위치" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#4B5563"/>
                    <TextBox x:Name="TxtErrorLogPath" IsReadOnly="True" Margin="0,0,0,20" Foreground="#6B7280" Background="#F9FAFB"/>
                    <TextBlock Text="버전" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#4B5563"/>
                    <TextBlock x:Name="TxtVersion" FontSize="14" Foreground="#2563EB" Margin="0,0,0,16"/>
                    <TextBlock Text="저장 방식" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#4B5563"/>
                    <TextBlock x:Name="TxtDataStorage" FontSize="14" Foreground="#6B7280"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
