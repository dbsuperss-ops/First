<Page x:Class="FileFlow.Pages.ClassifyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F8F9FA">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="파일 분류" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="폴더를 선택하고 규칙에 따라 파일을 분류하세요" FontSize="14" Foreground="#6B7280" Margin="0,4,0,0"/>
        </StackPanel>
        
        <Border Grid.Row="1" Margin="0,0,0,16" Padding="24,20" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="시나리오 선택" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#4B5563"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <ComboBox x:Name="CmbScenario" Grid.Column="0" SelectionChanged="CmbScenario_SelectionChanged"/>
                    <Button Grid.Column="2" Content="새로고침" Width="80" Click="BtnReloadScenarios_Click"/>
                </Grid>
                <TextBlock Text="폴더 설정" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="원본 폴더" FontWeight="SemiBold" Foreground="#4B5563"/>
                    <Grid Grid.Row="2" Grid.Column="0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtSourceFolder" Grid.Column="0"/>
                        <Button Grid.Column="2" Content="찾기" Width="60" Click="BtnBrowseSource_Click"/>
                    </Grid>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="대상 폴더 (수동 모드시 미지정 가능)" FontWeight="SemiBold" Foreground="#4B5563"/>
                    <Grid Grid.Row="2" Grid.Column="2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtTargetFolder" Grid.Column="0"/>
                        <Button Grid.Column="2" Content="찾기" Width="60" Click="BtnBrowseTarget_Click"/>
                    </Grid>
                </Grid>

                <Border Background="#F3F4F6" Padding="16" CornerRadius="8" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="추가 검색 필터 (수동 분류)" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ChkIncludeSubfolders" Grid.Column="0" Content="하위 폴더 포함" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="포함할 확장자 (.pdf 등):" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtExtFilter" Grid.Column="3" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="포함할 키워드:" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtKeywordFilter" Grid.Column="6" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="(제외할 항목 입력)" Foreground="#9CA3AF" VerticalAlignment="Center" Width="92"/>
                            <TextBlock Grid.Column="2" Text="제외할 확장자 (.exe 등):" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtExcludeExtFilter" Grid.Column="3" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="제외할 키워드:" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtExcludeKeywordFilter" Grid.Column="6" VerticalAlignment="Center"/>
                        </Grid>
                        <CheckBox x:Name="ChkManualOnly" Content="기존 시나리오 무시하고 위 수동 조건으로만 분류 (대상 미지정시 '수동분류_결과' 폴더 자동 생성)" FontWeight="SemiBold" Foreground="#2563EB"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="TxtScenarioInfo" Text="기본 분류" FontSize="13" Foreground="#2563EB" Margin="0,0,0,16"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="미리보기" Margin="0,0,10,0" Click="BtnPreview_Click"/>
                    <Button x:Name="BtnExecute" Content="분류 실행" IsEnabled="False" Background="#2563EB" Foreground="White" Click="BtnExecute_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="2" Padding="24,20" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
            <Grid>
                <StackPanel x:Name="PnlEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
                    <TextBlock x:Name="TxtEmptyState" Text="미리보기를 실행하세요" FontSize="16" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                </StackPanel>
                <Grid x:Name="PnlFileList" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <ListView x:Name="FileListView" Grid.Row="0" BorderBrush="#E5E7EB" BorderThickness="1">
                        <ListView.View><GridView>
                            <GridViewColumn Header="파일명" Width="220" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="원본 경로" Width="250" DisplayMemberBinding="{Binding SourcePath}"/>
                            <GridViewColumn Header="적용 규칙" Width="120" DisplayMemberBinding="{Binding RuleName}"/>
                            <GridViewColumn Header="이동 경로" Width="250" DisplayMemberBinding="{Binding TargetPath}"/>
                        </GridView></ListView.View>
                    </ListView>
                    <TextBlock x:Name="TxtStatus" Grid.Row="1" FontSize="13" Foreground="#6B7280" Margin="0,12,0,4"/>
                    <ProgressBar x:Name="PbProgress" Grid.Row="1" Height="10" Margin="0,32,0,0" Visibility="Collapsed" Maximum="100"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
