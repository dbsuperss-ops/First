<Page x:Class="FileFlow.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F8F9FA">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32" MaxWidth="1000">
            <TextBlock Text="대시보드" FontSize="26" FontWeight="Bold" Margin="0,0,0,6" Foreground="#111827"/>
            <TextBlock Text="파일 분류 현황을 한눈에 확인하세요" FontSize="14" Foreground="#6B7280" Margin="0,0,0,32"/>
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24,20" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="총 이동 파일" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,12"/>
                        <TextBlock x:Name="TxtTotalFiles" Text="0" FontSize="36" FontWeight="Bold" Foreground="#2563EB"/>
                        <TextBlock Text="개의 파일" FontSize="13" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24,20" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="실행 횟수" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,12"/>
                        <TextBlock x:Name="TxtExecutions" Text="0" FontSize="36" FontWeight="Bold" Foreground="#10B981"/>
                        <TextBlock Text="회 분류 실행" FontSize="13" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="24,20" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="시나리오 수" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,12"/>
                        <TextBlock x:Name="TxtScenarios" Text="0" FontSize="36" FontWeight="Bold" Foreground="#F59E0B"/>
                        <TextBlock Text="개의 시나리오" FontSize="13" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="6" Background="White" CornerRadius="12" Padding="24,20" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="최근 활동" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,12"/>
                        <TextBlock x:Name="TxtRecentCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#8B5CF6"/>
                        <TextBlock Text="건의 최근 기록" FontSize="13" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24,20" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="빠른 실행" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,4"/>
                        <TextBlock Text="자주 사용하는 기능에 빠르게 접근하세요" FontSize="13" Foreground="#6B7280" Margin="0,0,0,20"/>
                        <Button Click="BtnClassify_Click" Margin="0,0,0,10" HorizontalContentAlignment="Stretch">
                            <Grid><TextBlock Text="파일 분류 실행" FontSize="14"/><TextBlock Text="→" HorizontalAlignment="Right" Foreground="#9CA3AF"/></Grid>
                        </Button>
                        <Button Click="BtnDuplicate_Click" Margin="0,0,0,10" HorizontalContentAlignment="Stretch">
                            <Grid><TextBlock Text="중복 파일 검사" FontSize="14"/><TextBlock Text="→" HorizontalAlignment="Right" Foreground="#9CA3AF"/></Grid>
                        </Button>
                        <Button Click="BtnScenario_Click" HorizontalContentAlignment="Stretch">
                            <Grid><TextBlock Text="시나리오 관리" FontSize="14"/><TextBlock Text="→" HorizontalAlignment="Right" Foreground="#9CA3AF"/></Grid>
                        </Button>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24,20" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="최근 활동" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,4"/>
                        <TextBlock Text="최근 파일 처리 내역을 확인하세요" FontSize="13" Foreground="#6B7280" Margin="0,0,0,20"/>
                        <StackPanel x:Name="PnlNoActivity" HorizontalAlignment="Center" Margin="0,40,0,40">
                            <TextBlock Text="아직 활동 내역이 없습니다" FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="파일 분류를 실행하면 여기에 표시됩니다" FontSize="12" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <ListView x:Name="RecentActivityList" Visibility="Collapsed" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,12">
                                        <TextBlock Text="{Binding}" FontSize="14" Foreground="#4B5563"/>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
