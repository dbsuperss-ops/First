<Page x:Class="FileFlow.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F8F9FA">
    <Grid Margin="32,24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="통계" FontSize="28" FontWeight="Bold"/>
            <Button x:Name="BtnRefresh" Grid.Column="1" Content="새로고침" Click="BtnRefresh_Click"/>
        </Grid>
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20,18" Effect="{StaticResource CardShadow}"><StackPanel><TextBlock Text="총 이동" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,10"/><TextBlock x:Name="TxtTotalMoved" Text="0" FontSize="32" FontWeight="Bold" Foreground="#2563EB"/><TextBlock Text="개" FontSize="13" Foreground="#9CA3AF" Margin="0,2,0,0"/></StackPanel></Border>
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20,18" Effect="{StaticResource CardShadow}"><StackPanel><TextBlock Text="총 용량" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,10"/><TextBlock x:Name="TxtTotalSize" Text="0 B" FontSize="32" FontWeight="Bold" Foreground="#10B981"/></StackPanel></Border>
            <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="20,18" Effect="{StaticResource CardShadow}"><StackPanel><TextBlock Text="실행 횟수" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,10"/><TextBlock x:Name="TxtTotalRuns" Text="0" FontSize="32" FontWeight="Bold" Foreground="#F59E0B"/><TextBlock Text="회" FontSize="13" Foreground="#9CA3AF" Margin="0,2,0,0"/></StackPanel></Border>
            <Border Grid.Column="6" Background="White" CornerRadius="12" Padding="20,18" Effect="{StaticResource CardShadow}"><StackPanel><TextBlock Text="평균" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,10"/><TextBlock x:Name="TxtAvgPerRun" Text="0" FontSize="32" FontWeight="Bold" Foreground="#8B5CF6"/><TextBlock Text="개/회" FontSize="13" Foreground="#9CA3AF" Margin="0,2,0,0"/></StackPanel></Border>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Padding="24,20" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
                <StackPanel><TextBlock Text="규칙별 통계" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                    <StackPanel x:Name="PnlNoRuleStats" HorizontalAlignment="Center" Margin="0,30"><TextBlock Text="통계 없음" Foreground="#9CA3AF"/></StackPanel>
                    <ListView x:Name="LstRuleStats" Visibility="Collapsed" BorderBrush="#E5E7EB" BorderThickness="1"><ListView.View><GridView>
                        <GridViewColumn Header="규칙명" Width="180" DisplayMemberBinding="{Binding RuleName}"/>
                        <GridViewColumn Header="횟수" Width="100" DisplayMemberBinding="{Binding Count}"/>
                    </GridView></ListView.View></ListView>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="24,20" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
                <StackPanel><TextBlock Text="최근 실행" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                    <StackPanel x:Name="PnlNoRecentRuns" HorizontalAlignment="Center" Margin="0,30"><TextBlock Text="기록 없음" Foreground="#9CA3AF"/></StackPanel>
                    <ListView x:Name="LstRecentRuns" Visibility="Collapsed" BorderBrush="#E5E7EB" BorderThickness="1"><ListView.View><GridView>
                        <GridViewColumn Header="시나리오" Width="120" DisplayMemberBinding="{Binding ScenarioName}"/>
                        <GridViewColumn Header="시각" Width="130" DisplayMemberBinding="{Binding ExecutedAt}"/>
                        <GridViewColumn Header="파일" Width="60" DisplayMemberBinding="{Binding FileCount}"/>
                        <GridViewColumn Header="용량" Width="80" DisplayMemberBinding="{Binding SizeText}"/>
                    </GridView></ListView.View></ListView>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
