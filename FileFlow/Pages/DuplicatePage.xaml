<Page x:Class="FileFlow.Pages.DuplicatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F8F9FA">
    <Grid Margin="32,24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="중복 파일 검사" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
        <Border Grid.Row="1" Margin="0,0,0,16" Padding="24,20" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="검사 폴더" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#4B5563"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtFolder" Grid.Column="0"/>
                    <Button Grid.Column="2" Content="찾기" Width="60" Click="BtnBrowse_Click"/>
                </Grid>
                <Button x:Name="BtnScan" Content="검사 시작" Background="#2563EB" Foreground="White" Click="BtnScan_Click"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="2" Padding="24,20" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
            <Grid>
                <StackPanel x:Name="PnlEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="검사 시작을 눌러주세요" FontSize="16" Foreground="#9CA3AF"/>
                </StackPanel>
                <Grid x:Name="PnlResult" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="BtnSelectAll" Content="중복 전체 선택" Margin="0,0,10,0" Click="BtnSelectAll_Click"/>
                        <Button x:Name="BtnDelete" Content="선택 삭제" Foreground="#EF4444" Click="BtnDelete_Click"/>
                    </StackPanel>
                    <ListView x:Name="DuplicateList" Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1">
                        <ListView.View><GridView>
                            <GridViewColumn Width="40"><GridViewColumn.CellTemplate><DataTemplate><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" IsEnabled="{Binding CanSelect}"/></DataTemplate></GridViewColumn.CellTemplate></GridViewColumn>
                            <GridViewColumn Header="파일명" Width="220" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="경로" Width="350" DisplayMemberBinding="{Binding FilePath}"/>
                            <GridViewColumn Header="크기" Width="100" DisplayMemberBinding="{Binding FileSize}"/>
                        </GridView></ListView.View>
                    </ListView>
                    <TextBlock x:Name="TxtResult" Grid.Row="2" FontSize="13" Foreground="#6B7280" Margin="0,12,0,0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
