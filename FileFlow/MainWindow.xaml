<Window x:Class="FileFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileFlow" Width="1150" Height="750" MinWidth="900" MinHeight="600"
        Icon="pack://application:,,,/app_icon.ico"
        WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="20,24,20,24">
                    <TextBlock Text="FileFlow" FontSize="24" FontWeight="Bold" Foreground="#2563EB"/>
                </StackPanel>
                <ListBox x:Name="NavMenu" Grid.Row="1" BorderThickness="0" Background="Transparent" SelectionChanged="NavMenu_SelectionChanged" Padding="6,0">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="Margin" Value="4,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Foreground" Value="#333"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E8EAED"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
                                                <Setter Property="Foreground" Value="#1D4ED8"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Resources>
                    <ListBoxItem Tag="home"><TextBlock Text="홈" FontSize="14" VerticalAlignment="Center"/></ListBoxItem>
                    <ListBoxItem Tag="classify"><StackPanel Orientation="Horizontal"><TextBlock Text="📂" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/><TextBlock Text="파일 분류" FontSize="14" VerticalAlignment="Center"/></StackPanel></ListBoxItem>
                    <ListBoxItem Tag="scenario"><TextBlock Text="시나리오" FontSize="14" VerticalAlignment="Center"/></ListBoxItem>
                    <ListBoxItem Tag="duplicate"><TextBlock Text="중복 파일" FontSize="14" VerticalAlignment="Center"/></ListBoxItem>
                    <ListBoxItem Tag="log"><TextBlock Text="로그" FontSize="14" VerticalAlignment="Center"/></ListBoxItem>
                    <ListBoxItem Tag="statistics"><TextBlock Text="통계" FontSize="14" VerticalAlignment="Center"/></ListBoxItem>
                </ListBox>
                <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="6,6">
                    <ListBox x:Name="NavFooter" BorderThickness="0" Background="Transparent" SelectionChanged="NavFooter_SelectionChanged">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="16,12"/>
                                <Setter Property="Margin" Value="4,2"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}"><ContentPresenter/></Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#E8EAED"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/><Setter Property="Foreground" Value="#1D4ED8"/><Setter Property="FontWeight" Value="SemiBold"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.Resources>
                        <ListBoxItem Tag="settings"><TextBlock Text="설정" FontSize="14" VerticalAlignment="Center"/></ListBoxItem>
                    </ListBox>
                </Border>
            </Grid>
        </Border>
        <Frame x:Name="RootFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Source="Pages/HomePage.xaml"/>
    </Grid>
</Window>
