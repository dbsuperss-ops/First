<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DupeFinderPro.ViewModels.Duplicate"
             x:Class="DupeFinderPro.Views.Duplicate.ScanHistoryView"
             x:DataType="vm:ScanHistoryViewModel">

    <DockPanel Margin="32 28">

        <!-- ── 헤더 ──────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0 0 0 20">
            <TextBlock Classes="page-title" Text="스캔 기록"/>
            <TextBlock Classes="muted" Text="이전 스캔 및 결과를 확인하세요"/>
        </StackPanel>

        <!-- ── 필터 바 ──────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0 0 0 16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <TextBox Grid.Column="0" Classes="input"
                         Text="{Binding SearchText}"
                         Watermark="스캔 검색…"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Static vm:ScanHistoryViewModel.StatusFilters}"
                          SelectedItem="{Binding SelectedStatusFilter}"
                          MinWidth="130"/>
            </Grid>
        </Border>

        <!-- ── 목록 ──────────────────────────────────── -->
        <ScrollViewer>
            <StackPanel Spacing="10">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ScanHistoryItemViewModel">
                            <Border Classes="card">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <!-- 좌측: 정보 -->
                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Classes="section-title"
                                                       Text="{Binding Name}"/>
                                            <!-- 상태 배지 -->
                                            <Border CornerRadius="10" Padding="8 2"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#E6FFF5"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource StatusGreenBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Classes="muted"
                                                   Text="{Binding ResultSummary}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock Classes="muted"
                                                       Text="{Binding CreatedAt}"/>
                                            <TextBlock Classes="muted"
                                                       Text="{Binding Duration}"
                                                       IsVisible="{Binding IsCompleted}"/>
                                        </StackPanel>
                                        <TextBlock Classes="muted"
                                                   Text="{Binding Paths}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- 우측: 버튼 -->
                                    <Button Grid.Column="2"
                                            Classes="secondary"
                                            Content="결과 보기"
                                            VerticalAlignment="Center"
                                            IsEnabled="{Binding IsCompleted}"
                                            Command="{Binding DataContext.ViewResultsCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Classes="muted" Text="조건에 맞는 스캔이 없습니다."
                           HorizontalAlignment="Center" Margin="0 24"
                           IsVisible="{Binding !Items.Count}"/>
            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
