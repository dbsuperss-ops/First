<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DupeFinderPro.ViewModels"
             x:Class="DupeFinderPro.Views.HomeView"
             x:DataType="vm:HomeViewModel">

    <ScrollViewer Padding="32 28">
        <StackPanel Spacing="28">

            <!-- ── 헤더 ── -->
            <StackPanel Spacing="4">
                <TextBlock Classes="page-title" Text="홈"/>
                <TextBlock Classes="muted" Text="파일 분류 현황 및 중복 탐지 요약을 확인합니다."/>
            </StackPanel>

            <!-- ══════════ 파일 분류 섹션 ══════════ -->
            <StackPanel Spacing="16">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Classes="section-title" Text="📁 파일 분류 현황"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Classes="secondary" Content="시나리오 관리"
                                Command="{Binding GoToScenariosCommand}"/>
                        <Button Classes="primary"   Content="▶ 파일 정리 실행"
                                Command="{Binding GoToOrganizeCommand}"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">

                    <!-- 활성 시나리오 -->
                    <Border Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="muted" Text="활성 시나리오"/>
                            <TextBlock FontSize="32" FontWeight="Bold"
                                       Foreground="{StaticResource AccentTealBrush}"
                                       Text="{Binding ActiveScenarioCount}"/>
                            <TextBlock Classes="muted"
                                       Text="{Binding TotalScenariosCount, StringFormat='전체 {0}개'}"/>
                        </StackPanel>
                    </Border>

                    <!-- 정리된 파일 수 -->
                    <Border Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="muted" Text="정리된 파일"/>
                            <TextBlock FontSize="32" FontWeight="Bold"
                                       Foreground="{StaticResource AccentTealBrush}"
                                       Text="{Binding TotalFilesOrganized}"/>
                            <TextBlock Classes="muted" Text="개 파일"/>
                        </StackPanel>
                    </Border>

                    <!-- 정리된 용량 -->
                    <Border Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="muted" Text="정리된 용량"/>
                            <TextBlock FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AccentTealBrush}"
                                       Text="{Binding TotalBytesOrganized}"/>
                            <TextBlock Classes="muted" Text="누적 처리"/>
                        </StackPanel>
                    </Border>

                    <!-- 마지막 정리 -->
                    <Border Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="muted" Text="마지막 정리"/>
                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding LastOrganizeTime}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </StackPanel>

            <!-- ══════════ 구분선 ══════════ -->
            <Border Height="1" Background="{StaticResource BorderBrush}"/>

            <!-- ══════════ 중복 탐지 섹션 ══════════ -->
            <StackPanel Spacing="16">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Classes="section-title" Text="🔍 중복 파일 탐지"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Classes="secondary" Content="결과 보기"
                                Command="{Binding GoToDuplicateResultsCommand}"/>
                        <Button Classes="secondary" Content="새 스캔"
                                Command="{Binding GoToDuplicateScanCommand}"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">

                    <!-- 중복 그룹 수 -->
                    <Border Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="muted" Text="발견된 중복"/>
                            <TextBlock FontSize="32" FontWeight="Bold"
                                       Foreground="{StaticResource StatusOrangeBrush}"
                                       Text="{Binding TotalDuplicatesFound}"/>
                            <TextBlock Classes="muted" Text="그룹"/>
                        </StackPanel>
                    </Border>

                    <!-- 낭비 공간 -->
                    <Border Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="muted" Text="낭비 공간"/>
                            <TextBlock FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource StatusRedBrush}"
                                       Text="{Binding TotalWastedBytes}"/>
                            <TextBlock Classes="muted" Text="절약 가능"/>
                        </StackPanel>
                    </Border>

                    <!-- 총 스캔 횟수 -->
                    <Border Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="muted" Text="총 스캔 횟수"/>
                            <TextBlock FontSize="32" FontWeight="Bold"
                                       Foreground="{StaticResource StatusBlueBrush}"
                                       Text="{Binding TotalScansRun}"/>
                            <TextBlock Classes="muted" Text="회"/>
                        </StackPanel>
                    </Border>

                    <!-- 마지막 스캔 -->
                    <Border Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="muted" Text="마지막 스캔"/>
                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding LastScanTime}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
