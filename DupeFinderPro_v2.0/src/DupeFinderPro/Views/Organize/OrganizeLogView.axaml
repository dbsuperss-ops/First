<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DupeFinderPro.ViewModels.Organize"
             x:Class="DupeFinderPro.Views.Organize.OrganizeLogView"
             x:DataType="vm:OrganizeLogViewModel">

    <ScrollViewer Padding="32 28">
        <StackPanel Spacing="24">

            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Spacing="4">
                    <TextBlock Classes="page-title" Text="정리 기록"/>
                    <TextBlock Classes="muted" Text="파일 이동 기록을 확인하고 되돌릴 수 있습니다."/>
                </StackPanel>
                <Button Grid.Column="1" Classes="secondary" Content="마지막 작업 되돌리기"
                        Margin="0 0 8 0" VerticalAlignment="Center"
                        Command="{Binding UndoLastCommand}"
                        IsEnabled="{Binding HasEntries}"/>
                <Button Grid.Column="2" Classes="danger" Content="기록 삭제"
                        VerticalAlignment="Center"
                        Command="{Binding ClearLogCommand}"
                        IsEnabled="{Binding HasEntries}"/>
            </Grid>

            <!-- Status -->
            <TextBlock Classes="muted" Text="{Binding StatusText}"
                       IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <Border Classes="card">
                <StackPanel Spacing="0">
                    <!-- Header -->
                    <Grid ColumnDefinitions="160,*,*,60" Margin="16 8">
                        <TextBlock Grid.Column="0" Classes="label" Text="시각"/>
                        <TextBlock Grid.Column="1" Classes="label" Text="원본 경로"/>
                        <TextBlock Grid.Column="2" Classes="label" Text="대상 경로"/>
                        <TextBlock Grid.Column="3" Classes="label" Text="동작"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:OrganizeLogEntryViewModel">
                                <Grid ColumnDefinitions="160,*,*,60"
                                      Margin="16 6" RowSpacing="0">
                                    <TextBlock Grid.Column="0" Classes="muted" FontSize="12"
                                               Text="{Binding Timestamp}"/>
                                    <TextBlock Grid.Column="1" Classes="muted" FontSize="12"
                                               Text="{Binding SourcePath}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Classes="muted" FontSize="12"
                                               Text="{Binding TargetPath}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" FontSize="12"
                                               Text="{Binding Action}"
                                               Foreground="{StaticResource AccentTealBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Classes="muted" Padding="16"
                               Text="기록이 없습니다."
                               IsVisible="{Binding !HasEntries}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
