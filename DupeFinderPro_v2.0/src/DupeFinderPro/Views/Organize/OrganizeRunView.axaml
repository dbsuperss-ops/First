<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DupeFinderPro.ViewModels.Organize"
             x:Class="DupeFinderPro.Views.Organize.OrganizeRunView"
             x:DataType="vm:OrganizeRunViewModel">

    <ScrollViewer Padding="32 28">
        <StackPanel Spacing="24">

            <!-- ── 헤더 ── -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <TextBlock Classes="page-title" Text="파일 정리 실행"/>
                    <TextBlock Classes="muted" Text="시나리오를 선택하고 파일을 정리합니다."/>
                </StackPanel>
            </Grid>

            <!-- ── 폴더 오버라이드 (선택적) ── -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-title" Text="폴더 오버라이드 (선택사항)"/>
                    <TextBlock Classes="muted"
                               Text="시나리오의 원본 폴더 대신 다른 폴더를 지정하려면 아래에 드래그하거나 선택하세요."/>

                    <!-- 드래그앤드롭 존 -->
                    <Border x:Name="DropZone"
                            Height="80"
                            CornerRadius="8"
                            BorderThickness="2"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="#F7FAFC">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="4">
                            <TextBlock Text="📂 폴더를 여기에 드래그하거나"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Button Classes="secondary" Content="폴더 선택…"
                                    HorizontalAlignment="Center"
                                    Click="BrowseOverrideFolder_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- 선택된 오버라이드 폴더 표시 -->
                    <Grid IsVisible="{Binding HasOverrideFolder}" ColumnDefinitions="*,Auto">
                        <Border Classes="badge-blue" VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverrideSourceFolder}"
                                       Foreground="{StaticResource StatusBlueBrush}"
                                       FontSize="13"/>
                        </Border>
                        <Button Grid.Column="1" Classes="secondary" Content="✕ 제거"
                                Command="{Binding ClearOverrideFolderCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── 시나리오 선택 ── -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-title" Text="시나리오 선택"/>
                    <ComboBox ItemsSource="{Binding Scenarios}"
                              SelectedItem="{Binding SelectedScenario}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="시나리오를 선택하세요…">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ScenarioItemViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding ScenarioName}" FontWeight="SemiBold"/>
                                    <TextBlock Classes="muted"
                                               Text="{Binding SourceFolder, StringFormat='← {0}'}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- ── 상태 및 진행 ── -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="muted" Text="{Binding StatusText}"/>
                    <ProgressBar Value="{Binding Progress}" Maximum="100"
                                 Height="8" CornerRadius="4"
                                 IsVisible="{Binding IsBusy}"/>
                </StackPanel>
            </Border>

            <!-- ── 미리보기 결과 ── -->
            <Border Classes="card" IsVisible="{Binding HasPreview}">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-title" Text="미리보기"/>
                    <ScrollViewer MaxHeight="280">
                        <ItemsControl ItemsSource="{Binding PreviewItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ClassifyResultItemViewModel">
                                    <Border Padding="10 8" BorderThickness="0 0 0 1"
                                            BorderBrush="{StaticResource BorderBrush}">
                                        <Grid ColumnDefinitions="*,Auto,*">
                                            <TextBlock Text="{Binding SourceFileName}"
                                                       Classes="muted" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text=" → "
                                                       Foreground="{StaticResource AccentTealBrush}"
                                                       Margin="8 0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding TargetFolder}"
                                                       Classes="muted" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- ── 액션 버튼 ── -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Classes="secondary" Content="미리보기"
                        Command="{Binding PreviewCommand}"
                        IsEnabled="{Binding !IsBusy}"/>
                <Button Classes="primary" Content="▶ 실행"
                        Command="{Binding ExecuteCommand}"
                        IsEnabled="{Binding HasPreview}"/>
                <Button Classes="danger" Content="중단"
                        Command="{Binding CancelCommand}"
                        IsVisible="{Binding IsBusy}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
