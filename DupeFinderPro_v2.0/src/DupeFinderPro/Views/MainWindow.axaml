<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DupeFinderPro.ViewModels"
        xmlns:local="using:DupeFinderPro"
        x:Class="DupeFinderPro.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DupeFinder Pro"
        Icon="avares://DupeFinderPro/Assets/duple.ico"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <local:ViewLocator/>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="220,*">

        <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBgBrush}">
            <DockPanel>

                <!-- Brand -->
                <Border DockPanel.Dock="Top" Padding="20 24 20 16">
                    <StackPanel Spacing="2">
                        <TextBlock Text="FileFlow"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource AccentTealBrush}"/>
                        <TextBlock Text="Pro"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="White" Margin="-1 -4 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="12 8">

                    <!-- ── 홈 ── -->
                    <Button Classes="nav-item"
                            Classes.active="{Binding IsHomeActive}"
                            Command="{Binding NavigateToHomeCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⊞" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="홈" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- ── 파일 분류 section ── -->
                    <TextBlock Text="파일 분류"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#4ACBD5E0"
                               Margin="16 12 0 4"/>

                    <Button Classes="nav-item"
                            Classes.active="{Binding IsScenarioListActive}"
                            Command="{Binding NavigateToScenarioListCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="☰" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="시나리오" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav-item"
                            Classes.active="{Binding IsOrganizeRunActive}"
                            Command="{Binding NavigateToOrganizeRunCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="▶" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="파일 정리" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav-item"
                            Classes.active="{Binding IsOrganizeLogActive}"
                            Command="{Binding NavigateToOrganizeLogCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="◷" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="정리 기록" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav-item"
                            Classes.active="{Binding IsOrganizeStatsActive}"
                            Command="{Binding NavigateToOrganizeStatsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="▦" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="정리 통계" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- ── 구분선 ── -->
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8 12"/>

                    <!-- ── 중복 탐지 section ── -->
                    <TextBlock Text="중복 파일 탐지"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#4ACBD5E0"
                               Margin="16 0 0 4"/>

                    <Button Classes="nav-item"
                            Classes.active="{Binding IsDuplicateScanActive}"
                            Command="{Binding NavigateToDuplicateScanCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⊕" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="새 스캔" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav-item"
                            Classes.active="{Binding IsDuplicateResultsActive}"
                            Command="{Binding NavigateToDuplicateResultsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="◈" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="스캔 결과" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav-item"
                            Classes.active="{Binding IsDuplicateHistoryActive}"
                            Command="{Binding NavigateToDuplicateHistoryCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⊟" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="스캔 기록" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <Grid DockPanel.Dock="Bottom"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════ CONTENT ═══════════════════ -->
        <Border Grid.Column="1"
                Background="{StaticResource ContentBgBrush}">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>

    </Grid>
</Window>
