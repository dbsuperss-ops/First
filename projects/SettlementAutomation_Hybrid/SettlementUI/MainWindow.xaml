<Window x:Class="SettlementUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settlement Automation Premium" Height="700" Width="1000"
        MinHeight="520" MinWidth="760"
        Background="#0F172A" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        BorderThickness="1" BorderBrush="#334155"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#1E293B" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="#3B82F6" Margin="0,0,10,0"/>
                    <TextBlock Text="KSC SETTLEMENT ENGINE  v2.1"
                               Foreground="#94A3B8"
                               FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource IconButton}" Click="Minimize_Click"/>
                    <Button Content="&#xE923;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource IconButton}" Click="MaxRestore_Click"
                            x:Name="MaxRestoreBtn"/>
                    <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource IconButton}"
                            Foreground="#F43F5E" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT PANEL ═══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="데이터 결산 자동화" Foreground="White"
                               FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="해외 법인 결산 엑셀을 파싱하여 통합 DB로 정제합니다."
                               Foreground="#64748B" FontSize="13" Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- 지원 법인 배지 -->
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                    <WrapPanel.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                            <Setter Property="Padding" Value="8,3"/>
                            <Setter Property="Margin" Value="0,0,6,6"/>
                        </Style>
                    </WrapPanel.Resources>
                    <Border Background="#1E3A5F">
                        <TextBlock Text="KSCP · KRW" Foreground="#60A5FA" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#1E3A5F">
                        <TextBlock Text="KCTR · TRY" Foreground="#60A5FA" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#1E3A5F">
                        <TextBlock Text="KSCCZ · RMB" Foreground="#60A5FA" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#1E3A5F">
                        <TextBlock Text="KSCE · RSD" Foreground="#60A5FA" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#1E3A5F">
                        <TextBlock Text="KSCI · USD" Foreground="#60A5FA" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#16423C">
                        <TextBlock Text="KSC · KRW" Foreground="#34D399" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </WrapPanel>

                <!-- 경로 설정 -->
                <Border Grid.Row="2" Background="#1E293B" CornerRadius="10" Padding="16,12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.ColumnSpan="2" Text="대상 경로"
                                   Foreground="#38BDF8" FontWeight="SemiBold" FontSize="12"
                                   Margin="0,0,0,0"/>
                        <TextBox x:Name="PathTextBox" Grid.Row="2" Grid.Column="0"
                                 Background="#0F172A" Foreground="White"
                                 BorderBrush="#334155" BorderThickness="1"
                                 Padding="10,8" VerticalContentAlignment="Center"
                                 FontSize="13" CaretBrush="White"/>
                        <Button Grid.Row="2" Grid.Column="1"
                                Content="📁 선택" Style="{StaticResource ModernButton}"
                                Margin="8,0,0,0" FontSize="13" Padding="14,8"
                                Click="SelectPath_Click"/>
                    </Grid>
                </Border>

                <!-- 로그 레이블 -->
                <Grid Grid.Row="2" Margin="0,116,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="실행 로그" Foreground="#94A3B8"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                    <Button x:Name="ClearLogBtn" Grid.Column="1"
                            Content="지우기" Padding="10,3"
                            Background="#1E293B" Foreground="#64748B"
                            FontSize="11" Cursor="Hand" BorderThickness="0"
                            Margin="0,0,0,6" Click="ClearLog_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- 로그 영역 (GridSplitter로 크기 조절 가능) -->
                <Border Grid.Row="4" Background="#020617" CornerRadius="8"
                        BorderThickness="1" BorderBrush="#1E293B">
                    <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="LogText"
                                 Foreground="#10B981" Background="Transparent"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="13"
                                 Padding="14,12"
                                 IsReadOnly="True" BorderThickness="0"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Text="대기 중..."/>
                    </ScrollViewer>
                </Border>

                <!-- GridSplitter (로그 크기 조절) -->
                <GridSplitter Grid.Row="3"
                              Height="5" HorizontalAlignment="Stretch"
                              Background="Transparent" Cursor="SizeNS"
                              ShowsPreview="True"/>

                <!-- 하단 상태바 -->
                <Border Grid.Row="5" Margin="0,8,0,0">
                    <Grid>
                        <TextBlock x:Name="FooterText"
                                   Text="KSC Refiner  v2.1  |  지원: KSCP · KCTR · KSCCZ · KSCE · KSCI · KSC"
                                   Foreground="#334155" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="RowCountText" Text=""
                                   Foreground="#475569" FontSize="11"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- GridSplitter (좌/우 패널 너비 조절) -->
            <GridSplitter Grid.Column="1"
                          Width="5" VerticalAlignment="Stretch"
                          Background="#1E293B" Cursor="SizeWE"
                          ShowsPreview="True"/>

            <!-- ═══ RIGHT PANEL ═══ -->
            <StackPanel Grid.Column="2" Margin="16,0,0,0">

                <!-- 상태 카드 -->
                <Border Background="#1E293B" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="상태" Foreground="#64748B"
                                   FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="StatusLabel" Text="준비 완료"
                                   Foreground="#10B981" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <ProgressBar x:Name="ProgressBar" Height="6"
                                     Background="#0F172A" BorderThickness="0"
                                     Foreground="#3B82F6" IsIndeterminate="False"/>
                    </StackPanel>
                </Border>

                <!-- 실행 버튼 -->
                <Button Content="▶  자동 정제 엔진 가동"
                        Style="{StaticResource ModernButton}"
                        Height="54" Background="#3B82F6"
                        Click="StartRefinement_Click">
                    <Button.Effect>
                        <DropShadowEffect Color="#3B82F6" BlurRadius="18"
                                          ShadowDepth="0" Opacity="0.4"/>
                    </Button.Effect>
                </Button>

                <!-- 연도 선택 -->
                <Border Background="#1E293B" CornerRadius="10" Padding="16,12" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="기준 연도" Foreground="#64748B"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="YearCombo"
                                  Background="#0F172A" Foreground="White"
                                  BorderBrush="#334155" FontSize="13"
                                  HorizontalAlignment="Stretch"
                                  SelectedIndex="0"
                                  SelectionChanged="YearCombo_SelectionChanged">
                            <ComboBoxItem Content="2026" Foreground="White"/>
                            <ComboBoxItem Content="2025" Foreground="White"/>
                            <ComboBoxItem Content="2024" Foreground="White"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- 환율 설정 -->
                <Border Background="#1E293B" CornerRadius="10" Padding="16,12" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="환율 설정 (→ KRW)" Foreground="#64748B"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="USD" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox x:Name="RateUSD" Grid.Row="0" Grid.Column="1"
                                     Background="#0F172A" Foreground="White" BorderBrush="#334155"
                                     BorderThickness="1" Padding="8,4" FontSize="12"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="EUR" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox x:Name="RateEUR" Grid.Row="2" Grid.Column="1"
                                     Background="#0F172A" Foreground="White" BorderBrush="#334155"
                                     BorderThickness="1" Padding="8,4" FontSize="12"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="RMB" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox x:Name="RateRMB" Grid.Row="4" Grid.Column="1"
                                     Background="#0F172A" Foreground="White" BorderBrush="#334155"
                                     BorderThickness="1" Padding="8,4" FontSize="12"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="TRY" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox x:Name="RateTRY" Grid.Row="6" Grid.Column="1"
                                     Background="#0F172A" Foreground="White" BorderBrush="#334155"
                                     BorderThickness="1" Padding="8,4" FontSize="12"/>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="RSD" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox x:Name="RateRSD" Grid.Row="8" Grid.Column="1"
                                     Background="#0F172A" Foreground="White" BorderBrush="#334155"
                                     BorderThickness="1" Padding="8,4" FontSize="12"/>
                        </Grid>
                        <Button Content="환율 저장" Margin="0,10,0,0"
                                Click="SaveRatesBtn_Click"
                                Foreground="White"
                                BorderThickness="0" Padding="0,7"
                                FontSize="12" FontWeight="SemiBold"
                                HorizontalAlignment="Stretch"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#3B82F6"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2563EB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- 시스템 정보 -->
                <Border Background="#1E293B" CornerRadius="10" Padding="16,14" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="시스템 정보" Foreground="#64748B"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="엔진" Foreground="#475569" FontSize="12" Margin="0,0,12,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="openpyxl v3.14" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="출력" Foreground="#475569" FontSize="12" Margin="0,0,12,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="통합_DB · 경영보고서" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="법인" Foreground="#475569" FontSize="12" Margin="0,0,12,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="6개 (KSC 포함)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="모드" Foreground="#475569" FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Hybrid Automation" Foreground="#94A3B8" FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 결과 열기 버튼 -->
                <Button x:Name="OpenOutputBtn"
                        Content="📂  결과 폴더 열기"
                        Margin="0,16,0,0"
                        Background="#1E293B" Foreground="#94A3B8"
                        FontSize="13" Height="40"
                        IsEnabled="False"
                        Click="OpenOutput_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="12,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="True">
                                    <Setter Property="Background" Value="#1E3A5F"/>
                                    <Setter Property="Foreground" Value="#60A5FA"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Grid>

        <!-- Resize Grip -->
        <ResizeGrip Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Foreground="#334155" Margin="0,0,4,4"/>
    </Grid>
</Window>
