<Window x:Class="AIRoundTable.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AIRoundTable"
        Title="AI 원탁회의 — The Agora"
        Height="900" Width="1280"
        MinHeight="600" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E1A"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- ── 브러시 ─────────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BaseBrush"        Color="#0A0E1A"/>
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#0F1626"/>
        <SolidColorBrush x:Key="PanelBrush"       Color="#141B2D"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="#1E2A40"/>
        <SolidColorBrush x:Key="MutedBrush"       Color="#2A3550"/>
        <SolidColorBrush x:Key="TextBrush"        Color="#E2E8F0"/>
        <SolidColorBrush x:Key="DimBrush"         Color="#64748B"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#3B82F6"/>
        <SolidColorBrush x:Key="ActiveSessionBg"  Color="#141B2D"/>

        <!-- ── 다크 스크롤바 Thumb ─────────────────────────────────────────── -->
        <Style x:Key="DarkThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" Background="#2A3550" CornerRadius="3" Margin="1,2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D5070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 다크 스크롤바 ──────────────────────────────────────────────── -->
        <Style x:Key="DarkScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="MinWidth" Value="6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent" Width="6">
                                    <Track Name="PART_Track" IsDirectionReversed="True">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource DarkThumbStyle}"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── 탭 버튼 (비활성) ───────────────────────────────────────────── -->
        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="BorderBrush"     Value="#1E2A40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#141B2D"/>
                                <Setter Property="Foreground"                  Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 탭 버튼 (활성) ────────────────────────────────────────────── -->
        <Style x:Key="ActiveTabButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#0D1929"/>
            <Setter Property="Foreground"      Value="#3B82F6"/>
            <Setter Property="BorderBrush"     Value="#1E3A6E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F1E3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 새 원탁 버튼 ──────────────────────────────────────────────── -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#3B82F6"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0,11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 전송 버튼 ─────────────────────────────────────────────────── -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#3B82F6"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="44"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 세션 아이템 ────────────────────────────────────────────────── -->
        <Style x:Key="SessionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="Margin"                     Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent">
                            <Grid>
                                <Border x:Name="AccentBar"
                                        Width="2" HorizontalAlignment="Left"
                                        Background="#3B82F6"
                                        Visibility="Collapsed"/>
                                <ContentPresenter Margin="14,9,12,9"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd"        Property="Background" Value="#141B2D"/>
                                <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#0F1626"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 세션 ListBox ──────────────────────────────────────────────── -->
        <Style x:Key="SessionListBoxStyle" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- 상단 바                                                            -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <!-- 좌측: 로고 + 제목 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="8"
                            Background="#0D1929">
                        <Border Width="30" Height="30" CornerRadius="8"
                                BorderBrush="#1E3A6E" BorderThickness="1">
                            <TextBlock Text="⬡" FontSize="14"
                                       Foreground="#3B82F6"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="AI 원탁회의"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="THE AGORA"
                                   FontSize="9" FontFamily="Consolas"
                                   Foreground="#3D5070" Margin="0,-1,0,0"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <!-- 우측: 탭 + 저장 -->
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button x:Name="_tabConversation"
                            Content="💬  대화"
                            Style="{StaticResource ActiveTabButtonStyle}"
                            Click="TabConversation_Click"
                            Margin="0,0,6,0"/>
                    <Button x:Name="_tabParticipants"
                            Content="👤  참가자"
                            Style="{StaticResource OutlineButtonStyle}"
                            Click="TabParticipants_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- 본문                                                               -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── 사이드바 ─────────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- 사이드바 헤더 -->
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <TextBlock Text="세션 목록"
                                   FontSize="10" FontFamily="Consolas"
                                   FontWeight="Bold" Foreground="#3D5070"/>
                    </Border>

                    <!-- 새 원탁 버튼 -->
                    <Border DockPanel.Dock="Bottom" Padding="10,10">
                        <Button Content="＋  새 원탁회의"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="NewSession_Click"/>
                    </Border>

                    <!-- 세션 목록 -->
                    <ListBox x:Name="_sessionListBox"
                             Style="{StaticResource SessionListBoxStyle}"
                             ItemContainerStyle="{StaticResource SessionItemStyle}"
                             SelectionChanged="SessionListBox_SelectionChanged">
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBarStyle}"/>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ContextMenu>
                                        <ContextMenu Background="#141B2D"
                                                     BorderBrush="#1E2A40"
                                                     BorderThickness="1">
                                            <MenuItem Header="✏  이름 편집"
                                                      Foreground="#E2E8F0"
                                                      Background="Transparent"
                                                      Click="RenameSession_Click"/>
                                            <Separator Background="#1E2A40"/>
                                            <MenuItem Header="🗑  삭제"
                                                      Foreground="#EF4444"
                                                      Background="Transparent"
                                                      Click="DeleteSession_Click"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="26" Height="26" CornerRadius="7"
                                            Background="#141B2D"
                                            BorderBrush="#1E2A40" BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="💬" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   Foreground="#CBD5E1"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding CreatedAtText}"
                                                   FontSize="10" FontFamily="Consolas"
                                                   Foreground="#3D5070"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ── 메인 콘텐츠 ───────────────────────────────────────────── -->
            <Grid Grid.Column="1" Background="{StaticResource BaseBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 세션 헤더 -->
                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="22,13">
                    <StackPanel>
                        <TextBlock x:Name="_sessionTitle"
                                   Text="세션을 선택하시오"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock x:Name="_sessionDesc"
                                   Text=""
                                   FontSize="12"
                                   Foreground="{StaticResource DimBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── 대화 뷰 ─────────────────────────────────────────── -->
                <ScrollViewer x:Name="_messageScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PanningMode="VerticalOnly">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <ItemsControl x:Name="_messageList" Padding="0,12,0,20">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:MessageViewModel}">
                                <Grid Margin="20,6,20,0">
                                    <Grid.ContextMenu>
                                        <ContextMenu Background="#141B2D"
                                                     BorderBrush="#1E2A40"
                                                     BorderThickness="1">
                                            <MenuItem Header="📋  복사"
                                                      Foreground="#E2E8F0"
                                                      Background="Transparent"
                                                      Click="CopyMessage_Click"/>
                                            <Separator Background="#1E2A40"/>
                                            <MenuItem Header="🗑  삭제"
                                                      Foreground="#EF4444"
                                                      Background="Transparent"
                                                      Click="DeleteMessage_Click"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>

                                    <!-- 왼쪽 (AI 모델) -->
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Left"
                                                MaxWidth="620"
                                                Visibility="{Binding LeftVisibility}">
                                        <Border Width="30" Height="30" CornerRadius="8"
                                                Background="{Binding AvatarBrush}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding AvatarInitial}"
                                                       Foreground="White"
                                                       FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="8,0,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="2,0,0,4">
                                                <TextBlock Text="{Binding Sender}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding AvatarBrush}"/>
                                                <TextBlock Text="{Binding TimestampText}"
                                                           FontSize="10" FontFamily="Consolas"
                                                           Foreground="#3D5070"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border CornerRadius="4,12,12,12"
                                                    Padding="12,9"
                                                    Background="{Binding CardBackground}"
                                                    BorderBrush="{Binding CardBorderBrush}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           FontSize="13" LineHeight="22"
                                                           Foreground="#CBD5E1"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 오른쪽 (나) -->
                                    <StackPanel HorizontalAlignment="Right"
                                                MaxWidth="620"
                                                Visibility="{Binding RightVisibility}">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,0,2,4">
                                            <TextBlock Text="{Binding TimestampText}"
                                                       FontSize="10" FontFamily="Consolas"
                                                       Foreground="#3D5070"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Sender}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#3B82F6"/>
                                        </StackPanel>
                                        <Border CornerRadius="12,4,12,12"
                                                Padding="12,9"
                                                HorizontalAlignment="Right"
                                                Background="#0D1929"
                                                BorderBrush="#1E3A6E"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Content}"
                                                       TextWrapping="Wrap"
                                                       FontSize="13" LineHeight="22"
                                                       Foreground="#CBD5E1"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ── 참가자 뷰 ───────────────────────────────────────── -->
                <ScrollViewer x:Name="_participantsView"
                              Grid.Row="1"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <StackPanel Margin="28,24,28,24">
                        <TextBlock Text="원탁 참가자"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="현재 원탁회의에 참여 중인 AI 모델"
                                   FontSize="12" Foreground="{StaticResource DimBrush}"
                                   Margin="0,0,0,24"/>
                        <WrapPanel>
                            <!-- 나 -->
                            <Border Width="175" Margin="0,0,12,12" CornerRadius="12"
                                    Background="#141B2D"
                                    BorderBrush="#1E2A40" BorderThickness="1"
                                    Padding="0,22">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="25"
                                            Background="#0D1929"
                                            BorderBrush="#1E3A6E" BorderThickness="1"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="나" Foreground="#3B82F6"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="나" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E2E8F0"
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBlock Text="원탁 진행자"
                                               FontSize="11" Foreground="#64748B"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    <Border Background="#0D1929" CornerRadius="8"
                                            BorderBrush="#1E3A6E" BorderThickness="1"
                                            Padding="10,3" Margin="12,10,12,0">
                                        <TextBlock Text="진행자" FontSize="10"
                                                   Foreground="#3B82F6"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 제미나이 -->
                            <Border Width="175" Margin="0,0,12,12" CornerRadius="12"
                                    Background="#141B2D"
                                    BorderBrush="#1E2A40" BorderThickness="1"
                                    Padding="0,22">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="25"
                                            Background="#081F15"
                                            BorderBrush="#103D28" BorderThickness="1"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="G" Foreground="#10B981"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="제미나이" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E2E8F0"
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBlock Text="Google Gemini AI"
                                               FontSize="11" Foreground="#64748B"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    <Border Background="#081F15" CornerRadius="8"
                                            BorderBrush="#103D28" BorderThickness="1"
                                            Padding="10,3" Margin="12,10,12,0">
                                        <TextBlock Text="Google" FontSize="10"
                                                   Foreground="#10B981"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 코파일럿 -->
                            <Border Width="175" Margin="0,0,12,12" CornerRadius="12"
                                    Background="#141B2D"
                                    BorderBrush="#1E2A40" BorderThickness="1"
                                    Padding="0,22">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="25"
                                            Background="#081526"
                                            BorderBrush="#0E2545" BorderThickness="1"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="C" Foreground="#0078D4"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="코파일럿" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E2E8F0"
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBlock Text="Microsoft Copilot AI"
                                               FontSize="11" Foreground="#64748B"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    <Border Background="#081526" CornerRadius="8"
                                            BorderBrush="#0E2545" BorderThickness="1"
                                            Padding="10,3" Margin="12,10,12,0">
                                        <TextBlock Text="Microsoft" FontSize="10"
                                                   Foreground="#0078D4"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 클로드 -->
                            <Border Width="175" Margin="0,0,12,12" CornerRadius="12"
                                    Background="#141B2D"
                                    BorderBrush="#1E2A40" BorderThickness="1"
                                    Padding="0,22">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="25"
                                            Background="#1A1005"
                                            BorderBrush="#3D2A0A" BorderThickness="1"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="A" Foreground="#D97706"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="클로드" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E2E8F0"
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBlock Text="Anthropic Claude AI"
                                               FontSize="11" Foreground="#64748B"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    <Border Background="#1A1005" CornerRadius="8"
                                            BorderBrush="#3D2A0A" BorderThickness="1"
                                            Padding="10,3" Margin="12,10,12,0">
                                        <TextBlock Text="Anthropic" FontSize="10"
                                                   Foreground="#D97706"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- ── 입력 영역 ───────────────────────────────────────── -->
                <Border x:Name="_inputArea"
                        Grid.Row="2"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,12">
                    <StackPanel>
                        <!-- 발언자 선택 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                            <TextBlock Text="발언자"
                                       FontSize="10" FontFamily="Consolas"
                                       Foreground="#3D5070" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>

                            <!-- 나 -->
                            <Border x:Name="_senderMeBtn"
                                    CornerRadius="16" Padding="12,0" Height="28"
                                    Background="#0D1929"
                                    BorderBrush="#1E3A6E" BorderThickness="1"
                                    Cursor="Hand" Margin="0,0,6,0"
                                    MouseDown="SenderBtn_Click" Tag="나">
                                <TextBlock x:Name="_senderMeLbl"
                                           Text="나" VerticalAlignment="Center"
                                           Foreground="#3B82F6" FontSize="12" FontWeight="SemiBold"/>
                            </Border>

                            <!-- 제미나이 -->
                            <Border x:Name="_senderGeminiBtn"
                                    CornerRadius="16" Padding="12,0" Height="28"
                                    Background="#141B2D"
                                    BorderBrush="#1E2A40" BorderThickness="1"
                                    Cursor="Hand" Margin="0,0,6,0"
                                    MouseDown="SenderBtn_Click" Tag="제미나이">
                                <TextBlock x:Name="_senderGeminiLbl"
                                           Text="제미나이" VerticalAlignment="Center"
                                           Foreground="#64748B" FontSize="12"/>
                            </Border>

                            <!-- 코파일럿 -->
                            <Border x:Name="_senderCopilotBtn"
                                    CornerRadius="16" Padding="12,0" Height="28"
                                    Background="#141B2D"
                                    BorderBrush="#1E2A40" BorderThickness="1"
                                    Cursor="Hand" Margin="0,0,6,0"
                                    MouseDown="SenderBtn_Click" Tag="코파일럿">
                                <TextBlock x:Name="_senderCopilotLbl"
                                           Text="코파일럿" VerticalAlignment="Center"
                                           Foreground="#64748B" FontSize="12"/>
                            </Border>

                            <!-- 클로드 -->
                            <Border x:Name="_senderClaudeBtn"
                                    CornerRadius="16" Padding="12,0" Height="28"
                                    Background="#141B2D"
                                    BorderBrush="#1E2A40" BorderThickness="1"
                                    Cursor="Hand"
                                    MouseDown="SenderBtn_Click" Tag="클로드">
                                <TextBlock x:Name="_senderClaudeLbl"
                                           Text="클로드" VerticalAlignment="Center"
                                           Foreground="#64748B" FontSize="12"/>
                            </Border>
                        </StackPanel>

                        <!-- 텍스트 + 전송 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="10"
                                    BorderBrush="#1E2A40" BorderThickness="1"
                                    Background="#141B2D"
                                    Margin="0,0,8,0" MinHeight="44">
                                <Grid VerticalAlignment="Center">
                                    <TextBox x:Name="_inputTextBox"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="14,10"
                                             FontSize="13"
                                             Foreground="#E2E8F0"
                                             CaretBrush="#E2E8F0"
                                             SelectionBrush="#1E3A6E"
                                             VerticalContentAlignment="Center"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MaxHeight="120"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             TextChanged="InputTextBox_TextChanged"
                                             KeyDown="InputTextBox_KeyDown"/>
                                    <TextBlock x:Name="_placeholder"
                                               Text="메시지 입력 · Enter 전송 / Shift+Enter 줄바꿈"
                                               IsHitTestVisible="False"
                                               Foreground="#2A3550"
                                               FontSize="12"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Button Grid.Column="1"
                                    x:Name="_sendBtn"
                                    Style="{StaticResource SendButtonStyle}"
                                    Click="Send_Click"
                                    VerticalAlignment="Bottom">
                                <TextBlock Text="➤" FontSize="16" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
