<Window x:Class="AIRoundTable.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AIRoundTable"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="AI 백분토론 — The Digital Agora"
        Height="900" Width="1440"
        MinHeight="620" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="맑은 고딕">

    <Window.Resources>
        <!-- ── 브러시 ─────────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="PrimaryBrush"     Color="#3B82F6"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#10B981"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#64748B"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#94A3B8"/>
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgBrush"          Color="#F8FAFC"/>

        <!-- ── 사이드바 네비게이션 버튼 ──────────────────────────────────── -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="Foreground"                Value="#94A3B8"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                   Value="16,10"/>
            <Setter Property="FontSize"                  Value="13"/>
            <Setter Property="Cursor"                    Value="Hand"/>
            <Setter Property="FontFamily"                Value="맑은 고딕"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="8,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavActiveButtonStyle" TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background"  Value="#1E293B"/>
            <Setter Property="Foreground"  Value="#FFFFFF"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <!-- ── 아웃라인 버튼 ─────────────────────────────────────────────── -->
        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="맑은 고딕"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 주요 버튼 ─────────────────────────────────────────────────── -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="맑은 고딕"/>
            <Setter Property="Padding"         Value="0,11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 전송 버튼 ─────────────────────────────────────────────────── -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="46"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- 왼쪽 네비게이션 사이드바                                            -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#0F172A">
            <DockPanel>

                <!-- 로고 영역 -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,0">
                    <TextBlock Text="THE AGORA"
                               Foreground="#60A5FA" FontSize="9" FontWeight="Bold"/>
                    <TextBlock Text="AI 백분토론"
                               Foreground="White" FontSize="19" FontWeight="Bold"
                               Margin="0,3,0,0"/>
                    <TextBlock Text="The Digital Agora"
                               Foreground="#475569" FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- 구분선 -->
                <Border DockPanel.Dock="Top"
                        Height="1" Background="#1E293B" Margin="16,18,16,6"/>

                <!-- 네비게이션 -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="📊  토론 현황"
                            Style="{StaticResource NavActiveButtonStyle}"/>
                    <Button Content="⚙️  모델 설정"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Settings_Click"/>
                    <Button Content="📋  히스토리"
                            Style="{StaticResource NavButtonStyle}"
                            Click="History_Click"/>
                </StackPanel>

                <!-- 하단: 활성 모델 수 -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,8">
                    <Border Height="1" Background="#1E293B" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="#10B981"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="_activeModelCount"
                                   Text="0개 모델 참여 중"
                                   Foreground="#64748B" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- 하단: 새 토론 버튼 -->
                <Border DockPanel.Dock="Bottom" Margin="12,0,12,12">
                    <Button Content="＋  새 토론 시작"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="NewSession_Click"/>
                </Border>

                <!-- 여백 채우기 -->
                <Grid/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- 메인 영역 (3열 토론 + 브라우저 + 입력)                              -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── 3열 토론 영역 ──────────────────────────────────────────── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽 AI 패널 열 -->
                <Border Grid.Column="0"
                        Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="_leftAiPanels" Margin="10,14,10,14"/>
                    </ScrollViewer>
                </Border>

                <!-- 중앙 토론 창 -->
                <Grid Grid.Column="1" Background="{StaticResource SurfaceBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- LIVE 헤더 -->
                    <Border Grid.Row="0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="20,13">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="8" Height="8" CornerRadius="4"
                                        Background="#10B981" VerticalAlignment="Center"/>
                                <TextBlock Text="LIVE"
                                           Foreground="#10B981" FontSize="9" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="5,0,10,0"/>
                                <TextBlock x:Name="_debateTitle"
                                           Text="토론 진행 중"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="_messageCountText"
                                           Text="0개 메시지"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <Button Content="저장"
                                        Style="{StaticResource OutlineButtonStyle}"
                                        Click="SaveLog_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 메시지 목록 -->
                    <ScrollViewer x:Name="_messageScrollViewer"
                                  Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly">
                        <ItemsControl x:Name="_messageList" Padding="0,10,0,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:MessageViewModel}">
                                    <Grid Margin="20,8,20,0">
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="📋  복사"
                                                          Click="CopyMessage_Click"/>
                                                <Separator/>
                                                <MenuItem Header="🗑️  삭제"
                                                          Foreground="#EF4444"
                                                          Click="DeleteMessage_Click"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="34" Height="34" CornerRadius="17"
                                                Background="{Binding AvatarBrush}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding AvatarInitial}"
                                                       Foreground="White"
                                                       FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="{Binding Sender}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock Text="{Binding TimestampText}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextMuted}"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border CornerRadius="4,12,12,12"
                                                    Padding="12,9"
                                                    Background="{Binding CardBackground}"
                                                    BorderBrush="{Binding CardBorderBrush}"
                                                    BorderThickness="1"
                                                    MaxWidth="540"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           FontSize="13" LineHeight="21"
                                                           Foreground="#374151"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- AI 응답 대기 표시 (오버레이) -->
                    <Border x:Name="_thinkingBar"
                            Grid.Row="1"
                            VerticalAlignment="Top"
                            Visibility="Collapsed"
                            Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="0,0,0,1"
                            Padding="16,7">
                        <TextBlock x:Name="_thinkingText"
                                   Text="⏳  AI 모델 응답 대기 중..."
                                   FontSize="12" Foreground="#1D4ED8"/>
                    </Border>
                </Grid>

                <!-- 오른쪽 AI 패널 열 -->
                <Border Grid.Column="2"
                        Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="_rightAiPanels" Margin="10,14,10,14"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── 브라우저 패널 (접이식) ─────────────────────────────────── -->
            <Expander x:Name="_browserExpander"
                      Grid.Row="1"
                      Header="🌐  브라우저 패널 (AI 사이트 로그인 후 자동화 가능)"
                      IsExpanded="False"
                      Visibility="Collapsed"
                      Background="{StaticResource SurfaceBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="0,1,0,0">
                <TabControl x:Name="_browserTabControl"
                            Height="300"
                            BorderThickness="0"
                            Background="{StaticResource BgBrush}"
                            Padding="0"/>
            </Expander>

            <!-- ── 입력 영역 (사회자) ──────────────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 사회자 마이크 아이콘 -->
                    <Border Grid.Column="0"
                            Width="42" Height="42" CornerRadius="21"
                            Background="{StaticResource PrimaryLightBrush}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,12,2">
                        <TextBlock Text="🎙️" FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- 텍스트 입력 -->
                    <Border Grid.Column="1"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Background="{StaticResource BgBrush}"
                            Margin="0,0,10,0"
                            MinHeight="46">
                        <Grid VerticalAlignment="Center">
                            <TextBox x:Name="_inputTextBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="14,10"
                                     FontSize="13"
                                     FontFamily="맑은 고딕"
                                     Foreground="#374151"
                                     VerticalContentAlignment="Center"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MaxHeight="120"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     TextChanged="InputTextBox_TextChanged"
                                     KeyDown="InputTextBox_KeyDown"/>
                            <TextBlock x:Name="_placeholder"
                                       Text="논제를 입력하세요... (Enter 전송 / Shift+Enter 줄바꿈)"
                                       IsHitTestVisible="False"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 전송 버튼 -->
                    <Button Grid.Column="2"
                            x:Name="_sendBtn"
                            Style="{StaticResource SendButtonStyle}"
                            Click="Send_Click"
                            VerticalAlignment="Bottom">
                        <TextBlock Text="➤" FontSize="18" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
