<Window x:Class="PPT_Merger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PPT 통합 도구" Height="700" Width="960" MinHeight="600" MinWidth="800"
        FontFamily="맑은 고딕" FontSize="13">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 왼쪽 패널 ═══ -->
        <StackPanel Grid.Column="0">

            <!-- 소스 폴더 -->
            <GroupBox Header="소스 폴더">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtFolder" Grid.Column="0" Margin="0,0,4,0" IsReadOnly="True"/>
                    <Button Grid.Column="1" Content="찾아보기" Click="OnBrowseFolder"/>
                </Grid>
            </GroupBox>

            <!-- PPTX 파일 목록 -->
            <GroupBox Header="PPTX 파일 목록" Height="200">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="전체 선택" Width="80" Margin="0,0,4,0" Click="OnSelectAll"/>
                        <Button Content="전체 해제" Width="80" Click="OnSelectNone"/>
                    </StackPanel>
                    <ListBox x:Name="lstFiles" SelectionMode="Multiple"
                             CheckBox.Checked="OnFileChecked"
                             CheckBox.Unchecked="OnFileChecked">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked}"
                                          FontFamily="맑은 고딕" FontSize="12"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <!-- 키워드 필터 -->
            <GroupBox Header="키워드 필터 (해당 키워드가 포함된 슬라이드만 통합)">
                <TextBox x:Name="txtKeyword" Text="차주 계획"/>
            </GroupBox>

            <!-- 서식 설정 -->
            <GroupBox Header="서식 설정">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>

                    <!-- 폰트 -->
                    <Label Grid.Row="0" Grid.Column="0" Content="폰트:"/>
                    <ComboBox x:Name="cmbFont" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                              Height="26" VerticalContentAlignment="Center"
                              SelectionChanged="OnFormatChanged"/>

                    <!-- 크기 -->
                    <Label Grid.Row="1" Grid.Column="0" Content="크기:"/>
                    <Slider x:Name="sliderFontSize" Grid.Row="1" Grid.Column="1"
                            Minimum="6" Maximum="36" Value="11" TickFrequency="0.5" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnFormatChanged"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Text="{Binding ElementName=sliderFontSize, Path=Value, StringFormat={}{0:F1}}"/>
                    <Label Grid.Row="1" Grid.Column="3" Content="pt"/>

                    <!-- 굵게 / 색상 -->
                    <Label Grid.Row="2" Grid.Column="0" Content="스타일:"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="chkBold" Content="굵게" VerticalAlignment="Center"
                                  Checked="OnFormatChanged" Unchecked="OnFormatChanged" Margin="0,0,12,0"/>
                        <Label Content="색상:" VerticalAlignment="Center"/>
                        <Button x:Name="btnColor" Content="#1F1F1F" Width="80" Click="OnPickColor"/>
                    </StackPanel>

                    <!-- 정렬 -->
                    <Label Grid.Row="3" Grid.Column="0" Content="정렬:"/>
                    <ComboBox x:Name="cmbAlign" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                              Height="26" VerticalContentAlignment="Center"
                              SelectionChanged="OnFormatChanged">
                        <ComboBoxItem Content="왼쪽"/>
                        <ComboBoxItem Content="가운데"/>
                        <ComboBoxItem Content="오른쪽"/>
                        <ComboBoxItem Content="양쪽"/>
                    </ComboBox>

                    <!-- 줄간격 -->
                    <Label Grid.Row="4" Grid.Column="0" Content="줄간격:"/>
                    <Slider x:Name="sliderLineSpacing" Grid.Row="4" Grid.Column="1"
                            Minimum="0.5" Maximum="3.0" Value="1.2" TickFrequency="0.1" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" ValueChanged="OnFormatChanged"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Text="{Binding ElementName=sliderLineSpacing, Path=Value, StringFormat={}{0:F1}}"/>
                    <Label Grid.Row="4" Grid.Column="3" Content="배"/>
                </Grid>
            </GroupBox>

            <!-- 출력 파일 -->
            <GroupBox Header="출력 파일">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtOutput" Grid.Column="0" Margin="0,0,4,0" IsReadOnly="True"/>
                    <Button Grid.Column="1" Content="저장 위치" Click="OnBrowseOutput"/>
                </Grid>
            </GroupBox>

            <!-- 실행 버튼 -->
            <Button x:Name="btnRun" Content="통합 실행" Height="40" Margin="0,8,0,0"
                    FontSize="14" FontWeight="Bold" Click="OnRun"
                    Background="#0078D4" Foreground="White"/>
        </StackPanel>

        <!-- ═══ 오른쪽 패널 (미리보기 + 로그) ═══ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- 서식 미리보기 -->
            <GroupBox Grid.Row="0" Header="서식 미리보기">
                <Border BorderBrush="#DDDDDD" BorderThickness="1" Background="White"
                        MinHeight="80" Padding="12">
                    <TextBlock x:Name="txtPreview"
                               Text="가나다라마바사 ABC 123&#10;This is a preview text.&#10;차주 계획 내용이 이 서식으로 표시됩니다."
                               TextWrapping="Wrap"/>
                </Border>
            </GroupBox>

            <!-- 처리 로그 -->
            <GroupBox Grid.Row="2" Header="처리 로그">
                <TextBox x:Name="txtLog" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
                         Background="#1E1E1E" Foreground="#D4D4D4"/>
            </GroupBox>

            <!-- 빈 공간 (중간) -->
            <Border Grid.Row="1" Margin="0,4"/>
        </Grid>
    </Grid>
</Window>
