<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DupeFinderPro.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <!-- ── Brand palette ──────────────────────────────────────── -->
        <Color x:Key="SidebarBg">#1A1D27</Color>
        <Color x:Key="SidebarHover">#252836</Color>
        <Color x:Key="SidebarActive">#2A2D3E</Color>
        <Color x:Key="AccentTeal">#2DD4BF</Color>
        <Color x:Key="AccentTealDark">#0F9D8F</Color>
        <Color x:Key="ContentBg">#F0F4F8</Color>
        <Color x:Key="CardBg">#FFFFFF</Color>
        <Color x:Key="TextPrimary">#1A202C</Color>
        <Color x:Key="TextSecondary">#718096</Color>
        <Color x:Key="TextOnSidebar">#CBD5E0</Color>
        <Color x:Key="StatusGreen">#48BB78</Color>
        <Color x:Key="StatusRed">#FC8181</Color>
        <Color x:Key="StatusOrange">#F6AD55</Color>
        <Color x:Key="StatusBlue">#63B3ED</Color>
        <Color x:Key="BorderColor">#E2E8F0</Color>

        <SolidColorBrush x:Key="SidebarBgBrush"      Color="{StaticResource SidebarBg}"/>
        <SolidColorBrush x:Key="SidebarHoverBrush"   Color="{StaticResource SidebarHover}"/>
        <SolidColorBrush x:Key="SidebarActiveBrush"  Color="{StaticResource SidebarActive}"/>
        <SolidColorBrush x:Key="AccentTealBrush"     Color="{StaticResource AccentTeal}"/>
        <SolidColorBrush x:Key="AccentTealDarkBrush" Color="{StaticResource AccentTealDark}"/>
        <SolidColorBrush x:Key="ContentBgBrush"      Color="{StaticResource ContentBg}"/>
        <SolidColorBrush x:Key="CardBgBrush"         Color="{StaticResource CardBg}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"  Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextOnSidebarBrush"  Color="{StaticResource TextOnSidebar}"/>
        <SolidColorBrush x:Key="StatusGreenBrush"    Color="{StaticResource StatusGreen}"/>
        <SolidColorBrush x:Key="StatusRedBrush"      Color="{StaticResource StatusRed}"/>
        <SolidColorBrush x:Key="StatusOrangeBrush"   Color="{StaticResource StatusOrange}"/>
        <SolidColorBrush x:Key="StatusBlueBrush"     Color="{StaticResource StatusBlue}"/>
        <SolidColorBrush x:Key="BorderBrush"         Color="{StaticResource BorderColor}"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>

        <!-- ── Card style ──────────────────────────────────────────── -->
        <Style Selector="Border.card">
            <Setter Property="Background"     Value="{StaticResource CardBgBrush}"/>
            <Setter Property="CornerRadius"   Value="12"/>
            <Setter Property="Padding"        Value="20"/>
            <Setter Property="BoxShadow"      Value="0 2 8 0 #16000000"/>
        </Style>

        <!-- ── Accent primary button ──────────────────────────────── -->
        <Style Selector="Button.primary">
            <Setter Property="Background"  Value="{StaticResource AccentTealBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Padding"     Value="16 10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentTealDarkBrush}"/>
        </Style>

        <!-- ── Secondary / outline button ────────────────────────── -->
        <Style Selector="Button.secondary">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{StaticResource AccentTealBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource AccentTealBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="14 8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- ── Danger button ──────────────────────────────────────── -->
        <Style Selector="Button.danger">
            <Setter Property="Background"  Value="{StaticResource StatusRedBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Padding"     Value="14 8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- ── Sidebar nav item ───────────────────────────────────── -->
        <Style Selector="Button.nav-item">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{StaticResource TextOnSidebarBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"      Value="16 12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="FontSize"     Value="14"/>
        </Style>
        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}"/>
        </Style>
        <Style Selector="Button.nav-item.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
        </Style>
        <Style Selector="Button.nav-item.active">
            <Setter Property="Foreground" Value="{StaticResource AccentTealBrush}"/>
        </Style>

        <!-- ── Tag / badge pill ───────────────────────────────────── -->
        <Style Selector="Border.badge-green">
            <Setter Property="Background"   Value="#E6FFF5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="8 3"/>
        </Style>
        <Style Selector="Border.badge-red">
            <Setter Property="Background"   Value="#FFF5F5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="8 3"/>
        </Style>
        <Style Selector="Border.badge-orange">
            <Setter Property="Background"   Value="#FFFAF0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="8 3"/>
        </Style>
        <Style Selector="Border.badge-blue">
            <Setter Property="Background"   Value="#EBF8FF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="8 3"/>
        </Style>

        <!-- ── Section title ─────────────────────────────────────── -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize"     Value="24"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <!-- ── Form input ─────────────────────────────────────────── -->
        <Style Selector="TextBox.input">
            <Setter Property="Background"      Value="{StaticResource CardBgBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="10 8"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- ── Separator ──────────────────────────────────────────── -->
        <Style Selector="Separator">
            <Setter Property="Background"  Value="{StaticResource BorderBrush}"/>
            <Setter Property="Height"      Value="1"/>
            <Setter Property="Margin"      Value="0 8"/>
        </Style>
    </Application.Styles>
</Application>
