<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DupeFinderPro.ViewModels"
        xmlns:local="using:DupeFinderPro"
        x:Class="DupeFinderPro.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DupeFinder Pro"
        Icon="avares://DupeFinderPro/Assets/duple.ico"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <local:ViewLocator/>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="220,*">

        <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBgBrush}">
            <DockPanel>
                <!-- Logo / Brand -->
                <Border DockPanel.Dock="Top" Padding="20 24 20 16">
                    <StackPanel Spacing="2">
                        <TextBlock Text="DupeFinder"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource AccentTealBrush}"/>
                        <TextBlock Text="Pro"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="White" Margin="-1 -4 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="12 8">
                    <!-- Dashboard -->
                    <Button Classes="nav-item"
                            Classes.active="{Binding IsDashboardActive}"
                            Command="{Binding NavigateToDashboardCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⊞" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="대시보드" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- New Scan -->
                    <Button Classes="nav-item"
                            Classes.active="{Binding IsNewScanActive}"
                            Command="{Binding NavigateToNewScanCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⊕" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="새 스캔" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Scan History -->
                    <Button Classes="nav-item"
                            Classes.active="{Binding IsHistoryActive}"
                            Command="{Binding NavigateToHistoryCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="◷" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="스캔 기록" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Results -->
                    <Button Classes="nav-item"
                            Classes.active="{Binding IsResultsActive}"
                            Command="{Binding NavigateToResultsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="◈" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="결과" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Spacer -->
                <Grid DockPanel.Dock="Bottom"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════ CONTENT ═══════════════════ -->
        <Border Grid.Column="1"
                Background="{StaticResource ContentBgBrush}">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>

    </Grid>
</Window>
