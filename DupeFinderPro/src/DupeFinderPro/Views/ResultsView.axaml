<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DupeFinderPro.ViewModels"
             x:Class="DupeFinderPro.Views.ResultsView"
             x:DataType="vm:ResultsViewModel">

    <DockPanel Margin="32 28">

        <!-- ── 헤더 ──────────────────────────────────────── -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto"
              Margin="0 0 0 20">
            <StackPanel Spacing="4">
                <TextBlock Classes="page-title" Text="결과"/>
                <TextBlock Classes="muted" Text="{Binding ScanName}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                        VerticalAlignment="Center">
                <!-- 스캔 중 취소 -->
                <Button Classes="danger" Content="취소"
                        Command="{Binding CancelScanCommand}"
                        IsVisible="{Binding IsScanning}"/>
                <!-- 결과 일괄 설정 -->
                <Button Classes="secondary" Content="자동 선택"
                        Command="{Binding AutoSelectAllCommand}"
                        IsVisible="{Binding HasResults}"
                        ToolTip.Tip="각 그룹에서 첫 번째 파일은 유지, 나머지는 삭제로 설정"/>
                <Button Classes="secondary" Content="전체 삭제 설정"
                        Command="{Binding SetAllDeleteCommand}"
                        IsVisible="{Binding HasResults}"
                        ToolTip.Tip="Keep 파일을 제외한 모든 파일을 삭제로 설정"/>
                <Button Classes="secondary" Content="전체 격리 설정"
                        Command="{Binding SetAllQuarantineCommand}"
                        IsVisible="{Binding HasResults}"
                        ToolTip.Tip="Keep 파일을 제외한 모든 파일을 격리로 설정"/>
                <Button Classes="secondary" Content="전체 이동 설정"
                        Command="{Binding SetAllMoveCommand}"
                        IsVisible="{Binding HasResults}"
                        ToolTip.Tip="Keep 파일을 제외한 모든 파일을 이동으로 설정"/>
                <!-- 최종 적용 -->
                <Button Classes="primary" Content="전체 적용"
                        Command="{Binding ApplyAllCommand}"
                        IsVisible="{Binding HasResults}"
                        IsEnabled="{Binding !IsApplying}"/>
            </StackPanel>
        </Grid>

        <!-- ── 스캔 진행 패널 ──────────────────────────── -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0 0 0 16"
                IsVisible="{Binding IsScanning}">
            <StackPanel Spacing="12">
                <TextBlock Classes="section-title" Text="{Binding PhaseLabel}"/>
                <ProgressBar Minimum="0"
                             Maximum="{Binding ProgressMax}"
                             Value="{Binding ProgressValue}"
                             IsIndeterminate="{Binding IsIndeterminate}"
                             Height="8" CornerRadius="4"
                             Foreground="{StaticResource AccentTealBrush}"/>
                <TextBlock Classes="muted" Text="{Binding CurrentFile}"
                           TextWrapping="Wrap" MaxWidth="600"/>
            </StackPanel>
        </Border>

        <!-- ── 오류 패널 ──────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#FFF5F5" CornerRadius="8"
                Padding="14 12" Margin="0 0 0 16"
                IsVisible="{Binding HasScanError}">
            <StackPanel Spacing="4">
                <TextBlock Foreground="{StaticResource StatusRedBrush}"
                           FontWeight="SemiBold" Text="스캔 실패"/>
                <TextBlock Foreground="{StaticResource StatusRedBrush}"
                           Text="{Binding ErrorMessage}"/>
            </StackPanel>
        </Border>

        <!-- ── 요약 바 ──────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0 0 0 16"
                IsVisible="{Binding HasResults}">
            <StackPanel Orientation="Horizontal" Spacing="32">
                <StackPanel Spacing="2">
                    <TextBlock Classes="muted" Text="중복 그룹"/>
                    <TextBlock FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentTealBrush}"
                               Text="{Binding TotalGroups}"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Classes="muted" Text="검색된 파일"/>
                    <TextBlock FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="{Binding TotalFiles}"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Classes="muted" Text="낭비 공간"/>
                    <TextBlock FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource StatusOrangeBrush}"
                               Text="{Binding TotalWasted}"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Classes="muted" Text="소요 시간"/>
                    <TextBlock FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="{Binding ScanDuration}"/>
                </StackPanel>

                <!-- 격리 폴더 경로 -->
                <StackPanel Spacing="2" Margin="16 0 0 0">
                    <TextBlock Classes="label" Text="격리 폴더"/>
                    <TextBox Classes="input" MinWidth="220"
                             Text="{Binding QuarantinePath}"/>
                </StackPanel>

                <!-- 이동 대상 폴더 경로 -->
                <StackPanel Spacing="2" Margin="8 0 0 0">
                    <TextBlock Classes="label" Text="이동 대상 폴더"/>
                    <TextBox Classes="input" MinWidth="220"
                             Text="{Binding MoveToPath}"
                             Watermark="이동할 폴더 경로 입력"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── 중복 없음 ──────────────────────────────── -->
        <Border DockPanel.Dock="Top" Classes="card"
                IsVisible="{Binding IsEmpty}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8" Margin="0 24">
                <TextBlock FontSize="40" HorizontalAlignment="Center"
                           Text="✓"/>
                <TextBlock Classes="section-title"
                           HorizontalAlignment="Center"
                           Text="중복 파일이 없습니다!"/>
                <TextBlock Classes="muted"
                           HorizontalAlignment="Center"
                           Text="검색된 폴더에 중복 파일이 없습니다."/>
            </StackPanel>
        </Border>

        <!-- ── 중복 그룹 목록 ────────────────────────── -->
        <ScrollViewer IsVisible="{Binding HasResults}">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DuplicateGroupViewModel">
                        <Border Classes="card" Margin="0 0 0 12">
                            <StackPanel Spacing="0">

                                <!-- 그룹 헤더 -->
                                <Button Background="Transparent"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="0"
                                        Command="{Binding ToggleExpandedCommand}">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Classes="muted" Text="해시:"/>
                                            <TextBlock FontFamily="Cascadia Code,Consolas,monospace"
                                                       Text="{Binding Hash}"
                                                       Foreground="{StaticResource AccentTealBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Classes="muted"
                                                   Text="{Binding FileCount}"
                                                   Margin="16 0"/>
                                        <TextBlock Grid.Column="2"
                                                   Foreground="{StaticResource StatusOrangeBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding WastedBytes}"
                                                   Margin="0 0 16 0"/>
                                        <Button Grid.Column="3" Classes="secondary"
                                                Content="자동 선택"
                                                Command="{Binding AutoSelectCommand}"
                                                Padding="10 4" Margin="0 0 8 0"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding ExpandIcon}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Grid>
                                </Button>

                                <!-- 파일 행 -->
                                <ItemsControl ItemsSource="{Binding Files}"
                                              IsVisible="{Binding IsExpanded}"
                                              Margin="0 8 0 0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:FileEntryViewModel">
                                            <Border Padding="8 10"
                                                    BorderThickness="0 1 0 0"
                                                    BorderBrush="{StaticResource BorderBrush}">
                                                <Grid ColumnDefinitions="*,Auto,120,180">

                                                    <!-- 파일명 + 경로 -->
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Classes="label"
                                                                   Text="{Binding FileName}"/>
                                                        <TextBlock Classes="muted"
                                                                   Text="{Binding FullPath}"
                                                                   TextWrapping="Wrap"
                                                                   MaxWidth="320"/>
                                                    </StackPanel>

                                                    <!-- 크기 + 날짜 -->
                                                    <StackPanel Grid.Column="1"
                                                                Spacing="2" Margin="16 0">
                                                        <TextBlock Classes="label"
                                                                   Text="{Binding SizeFormatted}"/>
                                                        <TextBlock Classes="muted"
                                                                   Text="{Binding LastModified}"/>
                                                    </StackPanel>

                                                    <!-- 처리 상태 -->
                                                    <TextBlock Grid.Column="2"
                                                               Classes="muted"
                                                               Text="{Binding StatusMessage}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               IsVisible="{Binding IsDone}"/>

                                                    <!-- 작업 버튼 -->
                                                    <StackPanel Grid.Column="3"
                                                                Orientation="Horizontal"
                                                                Spacing="4"
                                                                IsVisible="{Binding !IsDone}">
                                                        <Button Padding="8 4"
                                                                FontSize="12"
                                                                Content="유지"
                                                                Background="#E6FFF5"
                                                                Foreground="{StaticResource StatusGreenBrush}"
                                                                Command="{Binding SetActionKeepCommand}"/>
                                                        <Button Padding="8 4"
                                                                FontSize="12"
                                                                Content="이동"
                                                                Background="#EBF8FF"
                                                                Foreground="{StaticResource StatusBlueBrush}"
                                                                Command="{Binding SetActionMoveCommand}"/>
                                                        <Button Padding="8 4"
                                                                FontSize="12"
                                                                Content="격리"
                                                                ToolTip.Tip="격리 폴더로 이동"
                                                                Background="#FFFAF0"
                                                                Foreground="{StaticResource StatusOrangeBrush}"
                                                                Command="{Binding SetActionQuarantineCommand}"/>
                                                        <Button Padding="8 4"
                                                                FontSize="12"
                                                                Content="삭제"
                                                                Background="#FFF5F5"
                                                                Foreground="{StaticResource StatusRedBrush}"
                                                                Command="{Binding SetActionDeleteCommand}"/>
                                                    </StackPanel>

                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
