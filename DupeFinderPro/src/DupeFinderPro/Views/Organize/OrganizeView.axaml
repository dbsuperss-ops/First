<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DupeFinderPro.ViewModels.Organize"
             x:Class="DupeFinderPro.Views.Organize.OrganizeView"
             x:DataType="vm:OrganizeViewModel">

    <ScrollViewer Padding="32 28">
        <StackPanel Spacing="24">

            <StackPanel Spacing="4">
                <TextBlock Classes="page-title" Text="파일 정리"/>
                <TextBlock Classes="muted" Text="시나리오를 선택하고 파일을 분류합니다."/>
            </StackPanel>

            <!-- Scenario selector + actions -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Classes="section-title" Text="시나리오 선택"/>
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Scenarios}"
                                  SelectedItem="{Binding SelectedScenario}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ScenarioItemViewModel">
                                    <TextBlock Text="{Binding ScenarioName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1" Classes="secondary" Content="미리보기"
                                Command="{Binding PreviewCommand}"
                                IsEnabled="{Binding !IsBusy}"/>
                        <Button Grid.Column="2" Classes="primary" Content="정리 실행"
                                Command="{Binding ExecuteCommand}"
                                IsEnabled="{Binding HasPreview}"/>
                        <Button Grid.Column="3" Classes="secondary" Content="취소"
                                Command="{Binding CancelCommand}"
                                IsEnabled="{Binding IsBusy}"/>
                    </Grid>

                    <!-- Progress bar -->
                    <ProgressBar Value="{Binding Progress}"
                                 Minimum="0" Maximum="100"
                                 IsVisible="{Binding IsBusy}"
                                 Height="6" CornerRadius="3"/>

                    <!-- Status -->
                    <TextBlock Classes="muted" Text="{Binding StatusText}"/>
                </StackPanel>
            </Border>

            <!-- Preview results -->
            <Border Classes="card" IsVisible="{Binding HasPreview}">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-title"
                               Text="{Binding PreviewItems.Count, StringFormat='미리보기 ({0}개 파일)'}"/>
                    <ItemsControl ItemsSource="{Binding PreviewItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ClassifyResultItemViewModel">
                                <Border Padding="8 6" BorderThickness="0 0 0 1"
                                        BorderBrush="{StaticResource BorderBrush}">
                                    <Grid ColumnDefinitions="*,*,80">
                                        <StackPanel Spacing="2">
                                            <TextBlock Classes="label" Text="{Binding FileName}"/>
                                            <TextBlock Classes="muted" FontSize="11" Text="{Binding SourcePath}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Classes="muted" FontSize="11" Text="{Binding TargetPath}"/>
                                            <TextBlock Classes="muted" FontSize="11"
                                                       Foreground="{StaticResource AccentTealBrush}"
                                                       Text="{Binding RuleName}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Classes="muted"
                                                   Text="{Binding FileSizeText}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
