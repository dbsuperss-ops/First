<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DupeFinderPro.ViewModels.Organize"
             x:Class="DupeFinderPro.Views.Organize.OrganizeStatisticsView"
             x:DataType="vm:OrganizeStatisticsViewModel">

    <ScrollViewer Padding="32 28">
        <StackPanel Spacing="24">

            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <TextBlock Classes="page-title" Text="정리 통계"/>
                    <TextBlock Classes="muted" Text="파일 분류 실행 기록 및 통계입니다."/>
                </StackPanel>
                <Button Grid.Column="1" Classes="danger" Content="기록 초기화"
                        VerticalAlignment="Center"
                        Command="{Binding ClearHistoryCommand}"/>
            </Grid>

            <!-- Summary cards -->
            <Grid ColumnDefinitions="*,*,*,*" Height="100">
                <Border Grid.Column="0" Classes="stat-card" Margin="0 0 8 0">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="muted" Text="총 실행 횟수"/>
                        <TextBlock Text="{Binding TotalExecutions}"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource AccentTealBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="stat-card" Margin="4 0">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="muted" Text="총 이동 파일"/>
                        <TextBlock Text="{Binding TotalFilesMoved}"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource StatusGreenBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="stat-card" Margin="4 0">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="muted" Text="총 이동 용량"/>
                        <TextBlock Text="{Binding TotalBytesMovedText}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource StatusOrangeBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Classes="stat-card" Margin="8 0 0 0">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="muted" Text="마지막 실행"/>
                        <TextBlock Text="{Binding LastExecutedAt}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- History table -->
            <Border Classes="card">
                <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="*,160,80,100" Margin="16 8">
                        <TextBlock Grid.Column="0" Classes="label" Text="시나리오"/>
                        <TextBlock Grid.Column="1" Classes="label" Text="실행 시각"/>
                        <TextBlock Grid.Column="2" Classes="label" Text="파일 수"/>
                        <TextBlock Grid.Column="3" Classes="label" Text="용량"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Records}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:StatRecordViewModel">
                                <Grid ColumnDefinitions="*,160,80,100"
                                      Margin="16 6">
                                    <TextBlock Grid.Column="0" Classes="label"
                                               Text="{Binding ScenarioName}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Classes="muted" FontSize="12"
                                               Text="{Binding ExecutedAt}"/>
                                    <TextBlock Grid.Column="2" Classes="muted" FontSize="12"
                                               Text="{Binding FileCount}"/>
                                    <TextBlock Grid.Column="3" Classes="muted" FontSize="12"
                                               Text="{Binding TotalBytesText}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Classes="muted" Padding="16"
                               Text="실행 기록이 없습니다."
                               IsVisible="{Binding !Records.Count}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
