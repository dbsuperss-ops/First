<Window x:Class="WorkMonitorWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WorkMonitorWpf"
        Title="WorkMonitor" Height="620" Width="900"
        MinHeight="450" MinWidth="650"
        Background="#F0F2F5"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 버튼 기본 스타일 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#006CBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005AA3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#D13438"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BC2F32"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 카드 스타일 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid 스타일 -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsIdle}" Value="True">
                    <Setter Property="Background" Value="#FFF9E6"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF3FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 헤더 -->
            <RowDefinition Height="Auto"/>  <!-- 현재 상태 카드 -->
            <RowDefinition Height="*"/>     <!-- 로그 테이블 -->
            <RowDefinition Height="Auto"/>  <!-- 하단 통계 -->
        </Grid.RowDefinitions>

        <!-- ===== 헤더 ===== -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 상태 표시등 + 타이틀 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="12" Height="12" Margin="0,0,10,0" Fill="#D13438"/>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="#1A1A2E" Text="WorkMonitor"/>
                </StackPanel>

                <!-- 상태 텍스트 -->
                <TextBlock Grid.Column="1" x:Name="StatusText"
                           Text="대기 중..." FontSize="13" Foreground="#666"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- 통계 + 시작/중지 버튼 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="StatsButton"
                            Content="통계"
                            Margin="0,0,8,0"
                            FontSize="13" Foreground="#0078D4" Background="Transparent"
                            BorderBrush="#0078D4" BorderThickness="1" Padding="16,8"
                            Cursor="Hand" Click="StatsButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EBF3FB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="ToggleButton"
                            Content="모니터링 시작"
                            Style="{StaticResource PrimaryButton}"
                            Click="ToggleButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 현재 활성 창 카드 ===== -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 현재 앱 -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="현재 앱" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <TextBlock x:Name="CurrentApp" Text="-" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1A1A2E" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- 현재 창 제목 -->
                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="창 제목" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <TextBlock x:Name="CurrentTitle" Text="-" FontSize="13"
                               Foreground="#444" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- 유휴 상태 -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="상태" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <Border x:Name="IdleBadge" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" Background="#DFF6DD">
                        <TextBlock x:Name="IdleText" Text="활성" FontSize="12" FontWeight="SemiBold" Foreground="#107C10"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 로그 테이블 ===== -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="활동 기록" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A2E" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CSV 내보내기" Margin="0,0,8,0"
                                FontSize="11" Foreground="#0078D4" Background="Transparent"
                                BorderBrush="#0078D4" BorderThickness="1" Padding="10,4"
                                Cursor="Hand" Click="ExportCsv_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EBF3FB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="기록 초기화"
                                FontSize="11" Foreground="#666" Background="Transparent"
                                BorderBrush="#CCC" BorderThickness="1" Padding="10,4"
                                Cursor="Hand" Click="ClearLogs_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <DataGrid Grid.Row="1" x:Name="LogGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F0F0F0"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#FAFAFA"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          CanUserResizeRows="False"
                          FontSize="12">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#888"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="시간" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="75"/>
                        <DataGridTextColumn Header="앱" Binding="{Binding ProcessName}" Width="140"/>
                        <DataGridTextColumn Header="창 제목" Binding="{Binding WindowTitle}" Width="*"/>
                        <DataGridTemplateColumn Header="상태" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Center" Margin="4,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#DFF6DD"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIdle}" Value="True">
                                                        <Setter Property="Background" Value="#FFF4CE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="활성"/>
                                                    <Setter Property="Foreground" Value="#107C10"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsIdle}" Value="True">
                                                            <Setter Property="Text" Value="유휴"/>
                                                            <Setter Property="Foreground" Value="#9D5D00"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ===== 하단 통계 바 ===== -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="총 기록" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TotalCount" Text="0" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="건" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <Ellipse Width="8" Height="8" Fill="#107C10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="활성" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="ActiveCount" Text="0" FontSize="13" FontWeight="SemiBold" Foreground="#107C10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="건" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#9D5D00" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="유휴" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="IdleCount" Text="0" FontSize="13" FontWeight="SemiBold" Foreground="#9D5D00" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="건" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
